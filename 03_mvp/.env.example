# Clé API Anthropic — obtenue sur https://console.anthropic.com/
# ⚠ Ne pas commiter ce fichier. Copier en .env et remplir.
ANTHROPIC_API_KEY=sk-ant-...

# Modèle Claude utilisé (défaut : Sonnet 4.6, bon ratio qualité/coût)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Port du serveur local
PORT=4747

# Mode démo (pas d'appel API) : si vide, utilise la vraie API
DEMO_MODE=
