const TYPE_LABEL = { livraison:"Livraison", "décision":"Décision", "écart":"Écart", dérive:"Dérive", "ajout-hors-plan":"Ajout hors plan" };
const TYPE_COLOR = { livraison:"emerald", "décision":"sky", "écart":"amber", dérive:"rose", "ajout-hors-plan":"violet" };

// ──────────────────────────────────────────────────────────────
// GitHub state — chargé depuis _audit-2026-04-25/github-state.json
// si présent. Permet d'enrichir les références issue/PR avec
// labels, milestone, assignees, reviews. Tolérant à l'absence
// du fichier : on dégrade en lien minimal.
// ──────────────────────────────────────────────────────────────
const GH_REPO = "feycoil/aiCEO";
let GH_STATE = { loaded: false, generated_at: null, issues: {}, pulls: {}, milestones: {}, labels: {} };

async function loadGhState() {
  try {
    const r = await fetch("_audit-2026-04-25/github-state.json", { cache: "no-store" });
    if (!r.ok) return;
    const data = await r.json();
    GH_STATE.loaded = true;
    GH_STATE.generated_at = data.generated_at;
    (data.issues || []).forEach(i => { GH_STATE.issues[i.number] = i; });
    (data.pulls  || []).forEach(p => { GH_STATE.pulls[p.number]  = p; });
    (data.milestones || []).forEach(m => { GH_STATE.milestones[m.title] = m; GH_STATE.milestones[m.number] = m; });
    (data.labels || []).forEach(l => { GH_STATE.labels[l.name] = l; });
  } catch (e) {
    // 404 ou parse error : on continue silencieusement
  }
}

function ghContrastColor(hex) {
  if (!hex) return "#1f2328";
  hex = hex.replace("#","");
  if (hex.length !== 6) return "#1f2328";
  const r = parseInt(hex.slice(0,2),16), g = parseInt(hex.slice(2,4),16), b = parseInt(hex.slice(4,6),16);
  const yiq = (r*299 + g*587 + b*114) / 1000;
  return yiq >= 150 ? "#1f2328" : "#ffffff";
}

function ghIconIssue(state) {
  const fill = state === "open" ? "#1a7f37" : "#8250df";
  return `<svg class="gh-icon" viewBox="0 0 16 16" fill="${fill}" aria-hidden="true"><path d="M8 9.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z"/><path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0Zm0 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13Z"/></svg>`;
}
function ghIconPr(state, merged, draft) {
  const fill = merged ? "#8250df" : (draft ? "#6e7781" : (state === "open" ? "#1a7f37" : "#cf222e"));
  return `<svg class="gh-icon" viewBox="0 0 16 16" fill="${fill}" aria-hidden="true"><path d="M1.5 3.25a2.25 2.25 0 1 1 3 2.122v5.256a2.25 2.25 0 1 1-1.5 0V5.372A2.25 2.25 0 0 1 1.5 3.25Zm5.677-.177L9.573.677A.25.25 0 0 1 10 .854V2.5h1A2.5 2.5 0 0 1 13.5 5v5.628a2.25 2.25 0 1 1-1.5 0V5a1 1 0 0 0-1-1h-1v1.646a.25.25 0 0 1-.427.177L7.177 3.427a.25.25 0 0 1 0-.354ZM3.75 2.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm0 9.5a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5Zm8.25.75a.75.75 0 1 0 1.5 0 .75.75 0 0 0-1.5 0Z"/></svg>`;
}

function ghIssueRef(num, opts) {
  opts = opts || {};
  const meta = GH_STATE.issues[num];
  const url = meta ? meta.html_url : `https://github.com/${GH_REPO}/issues/${num}`;
  const state = meta ? meta.state : null;
  const stateLabel = state === "open" ? "Open" : (meta && meta.state_reason === "not_planned" ? "Closed" : "Closed");
  const stateClass = state === "open" ? "open" : (meta && meta.state_reason === "not_planned" ? "notplanned" : "closed");
  const titleSnip = meta && meta.title ? `<span class="gh-title">${escapeHtml(meta.title)}</span>` : "";
  const stateBadge = state ? `<span class="gh-state ${stateClass}">${stateLabel}</span>` : "";
  return `<a class="gh-ref" href="${url}" target="_blank" rel="noopener" title="Issue #${num}${meta ? ' — ' + meta.title : ''}">${ghIconIssue(state || "open")}<span class="gh-num">#${num}</span>${stateBadge}${opts.title ? titleSnip : ""}</a>`;
}

function ghPrRef(num, opts) {
  opts = opts || {};
  const meta = GH_STATE.pulls[num];
  const url = meta ? meta.html_url : `https://github.com/${GH_REPO}/pull/${num}`;
  let stateClass = "open", stateLabel = "Open";
  if (meta) {
    if (meta.merged) { stateClass = "merged"; stateLabel = "Merged"; }
    else if (meta.draft) { stateClass = "draft"; stateLabel = "Draft"; }
    else if (meta.state === "closed") { stateClass = "notplanned"; stateLabel = "Closed"; }
    else { stateClass = "open"; stateLabel = "Open"; }
  }
  const titleSnip = meta && meta.title ? `<span class="gh-title">${escapeHtml(meta.title)}</span>` : "";
  const stateBadge = meta ? `<span class="gh-state ${stateClass}">${stateLabel}</span>` : "";
  return `<a class="gh-ref" href="${url}" target="_blank" rel="noopener" title="PR #${num}${meta ? ' — ' + meta.title : ''}">${ghIconPr(meta?.state, meta?.merged, meta?.draft)}<span class="gh-num">#${num}</span>${stateBadge}${opts.title ? titleSnip : ""}</a>`;
}

function ghMilestoneRef(title) {
  const meta = GH_STATE.milestones[title];
  const url = meta ? meta.html_url : `https://github.com/${GH_REPO}/milestone/${encodeURIComponent(title)}`;
  const cls = meta && meta.state === "closed" ? "gh-milestone closed" : "gh-milestone";
  const progress = (meta && (meta.open_issues + meta.closed_issues) > 0)
    ? ` ${meta.closed_issues}/${meta.open_issues + meta.closed_issues}`
    : "";
  return `<a class="${cls}" href="${url}" target="_blank" rel="noopener">📌 ${escapeHtml(title)}${progress}</a>`;
}

function ghLabelChip(name) {
  const meta = GH_STATE.labels[name];
  const bg = meta && meta.color ? "#" + meta.color : "#eaeef2";
  const fg = ghContrastColor(meta && meta.color ? meta.color : "eaeef2");
  return `<span class="gh-label" style="--gh-bg:${bg}; --gh-fg:${fg};">${escapeHtml(name)}</span>`;
}

function ghAvatar(login, role, reviewState) {
  const initials = login ? login.slice(0,2).toUpperCase() : "?";
  const cls = role === "reviewer" ? `gh-avatar reviewer${reviewState ? ' ' + reviewState.toLowerCase() : ''}` : "gh-avatar";
  return `<a class="${cls}" href="https://github.com/${login}" target="_blank" rel="noopener" title="${escapeHtml(login)}${role === "reviewer" && reviewState ? ' · ' + reviewState : ''}">${escapeHtml(initials)}</a>`;
}

// Compose une rangée compacte (issue + PR + milestone + branch + tag)
function renderGhRef(gh) {
  if (!gh) return "";
  const parts = [];
  // Issues
  if (Array.isArray(gh.issues)) gh.issues.forEach(n => parts.push(ghIssueRef(n)));
  if (gh.issue) parts.push(ghIssueRef(gh.issue));
  // PRs
  if (Array.isArray(gh.prs)) gh.prs.forEach(n => parts.push(ghPrRef(n)));
  if (gh.pr) parts.push(ghPrRef(gh.pr));
  // Milestone
  if (gh.milestone) parts.push(ghMilestoneRef(gh.milestone));
  // Branch / tag / commit
  if (gh.branch) {
    const url = `https://github.com/${GH_REPO}/tree/${encodeURIComponent(gh.branch)}`;
    parts.push(`<a class="gh-branch" href="${url}" target="_blank" rel="noopener">${escapeHtml(gh.branch)}</a>`);
  }
  if (gh.tag) {
    const url = `https://github.com/${GH_REPO}/releases/tag/${encodeURIComponent(gh.tag)}`;
    parts.push(`<a class="gh-tag" href="${url}" target="_blank" rel="noopener">${escapeHtml(gh.tag)}</a>`);
  }
  if (gh.commit) {
    const url = `https://github.com/${GH_REPO}/commit/${gh.commit}`;
    parts.push(`<a class="gh-commit" href="${url}" target="_blank" rel="noopener">${escapeHtml(gh.commit.slice(0,7))}</a>`);
  }
  if (parts.length === 0) return "";
  return `<div class="gh-refs compact">${parts.join("")}</div>`;
}

// Bloc détaillé (drawer milestone) avec labels + assignees + reviewers
function renderGhDetail(gh) {
  if (!gh) return "";
  const rows = [];
  // Issue détaillée si dispo
  let issueMeta = null, prMeta = null;
  if (gh.issue && GH_STATE.issues[gh.issue]) issueMeta = GH_STATE.issues[gh.issue];
  if (gh.pr && GH_STATE.pulls[gh.pr]) prMeta = GH_STATE.pulls[gh.pr];

  const refLine = renderGhRef(gh);
  if (refLine) rows.push(`<div class="gh-row">${refLine.replace('<div class="gh-refs compact">','').replace('</div>','')}</div>`);

  // Labels (issue + PR)
  const labels = new Set();
  if (issueMeta && issueMeta.labels) issueMeta.labels.forEach(l => labels.add(l.name));
  if (prMeta && prMeta.labels)       prMeta.labels.forEach(l => labels.add(l.name));
  if (labels.size) {
    rows.push(`<div class="gh-row"><span class="gh-row-label">Labels</span>${[...labels].map(n => ghLabelChip(n)).join(" ")}</div>`);
  }
  // Assignees
  const assignees = new Set();
  if (issueMeta && issueMeta.assignees) issueMeta.assignees.forEach(a => assignees.add(a));
  if (prMeta && prMeta.assignees)       prMeta.assignees.forEach(a => assignees.add(a));
  if (assignees.size) {
    rows.push(`<div class="gh-row"><span class="gh-row-label">Assignees</span>${[...assignees].map(a => ghAvatar(a, "assignee")).join("")}</div>`);
  }
  // Reviewers
  if (prMeta) {
    const reviewers = [];
    (prMeta.requested_reviewers || []).forEach(r => reviewers.push({ login: r, state: "PENDING" }));
    (prMeta.reviews || []).forEach(r => reviewers.push({ login: r.user, state: r.state }));
    if (reviewers.length) {
      rows.push(`<div class="gh-row"><span class="gh-row-label">Reviewers</span>${reviewers.map(r => ghAvatar(r.login, "reviewer", r.state)).join("")}</div>`);
    }
  }
  if (rows.length === 0) return "";
  const stale = !GH_STATE.loaded
    ? `<div class="gh-refs-stale">⚠️ Données GitHub non chargées — exécutez <code>04_docs/_audit-2026-04-25/consistence-dump.ps1</code> depuis Windows pour enrichir labels/assignees/reviewers.</div>`
    : "";
  return `<div class="gh-detail"><h5>GitHub</h5>${rows.join("")}${stale}</div>`;
}

// ──────────────────────────────────────────────────────────────
// Helpers
// ──────────────────────────────────────────────────────────────

function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"}[c]));
}

const STATUS_LABEL = { done:"Fait", doing:"En cours", todo:"À faire" };
const LANE_LABEL = { web:"App Web", mvp:"MVP Node", hub:"Hub v0.5", v2:"V1 → V2 → V3" };

// ──────────────────────────────────────────────────────────────
// TAB 1 — Render timeline grid
// ──────────────────────────────────────────────────────────────

function renderTimeline() {
  const grid = document.getElementById("tl-grid");
  PERIODS.forEach(p => {
    if (p.banner) {
      const row = document.createElement("div");
      row.className = "tl-hub-row";
      row.setAttribute("role", "row");

      const period = document.createElement("div");
      period.className = "tl-period" + (p.now ? " now" : "");
      period.innerHTML = `<div class="month">${escapeHtml(p.label)}</div><div class="sub">${escapeHtml(p.sub)}</div>`;

      const banner = document.createElement("button");
      banner.type = "button";
      banner.className = "tl-hub-banner";
      banner.dataset.id = V05_HUB.id;
      banner.dataset.lane = V05_HUB.lane;
      banner.dataset.status = V05_HUB.status;
      banner.setAttribute("aria-label", `${V05_HUB.title} — ${V05_HUB.date}`);
      banner.innerHTML = `
        <div class="star" aria-hidden="true">v0.5</div>
        <div>
          <h3>Hub fusion · produit unifié</h3>
          <p>App Web + MVP fusionnés en une seule UI branchée sur SQLite + Zod + Service Windows. Cible <strong>juillet 2026</strong>. 10 semaines · 5 phases. Cliquer pour le détail.</p>
        </div>
        <div class="stamp">110 k€ · 2,6 ETP</div>
      `;
      banner.addEventListener("click", () => selectMilestone(V05_HUB));
      banner.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") { e.preventDefault(); selectMilestone(V05_HUB); }
      });

      row.appendChild(period);
      row.appendChild(banner);
      grid.appendChild(row);
      return;
    }

    const row = document.createElement("div");
    row.className = "tl-row" + (p.now ? " now" : "");
    row.setAttribute("role", "row");

    const period = document.createElement("div");
    period.className = "tl-period";
    period.innerHTML = `<div class="month">${escapeHtml(p.label)}</div><div class="sub">${escapeHtml(p.sub)}</div>${p.now ? '<span class="now-pill">Aujourd\'hui · 26 avr.</span>' : ''}`;
    row.appendChild(period);

    ["web","mvp","hub","v2"].forEach(lane => {
      const cell = document.createElement("div");
      cell.className = "tl-cell";
      cell.dataset.lane = lane;
      const events = MILESTONES.filter(m => m.period === p.id && m.lane === lane);
      if (events.length === 0) {
        const empty = document.createElement("span");
        empty.className = "tl-cell-empty";
        empty.textContent = "—";
        cell.appendChild(empty);
      } else {
        events.forEach(m => {
          const ev = document.createElement("button");
          ev.type = "button";
          ev.className = `tl-event ${m.lane} s-${m.status}`;
          ev.dataset.id = m.id;
          ev.dataset.lane = m.lane;
          ev.dataset.status = m.status;
          ev.setAttribute("aria-label", `${m.title} — ${m.date} — ${STATUS_LABEL[m.status]}`);
          ev.innerHTML = `
            <span class="tle-title">${escapeHtml(m.title)}</span>
            <span class="tle-date">${escapeHtml(m.date)}</span>
            <span class="tle-status">${escapeHtml(STATUS_LABEL[m.status])}</span>
          `;
          ev.addEventListener("click", () => selectMilestone(m));
          ev.addEventListener("keydown", (e) => {
            if (e.key === "Enter" || e.key === " ") { e.preventDefault(); selectMilestone(m); }
          });
          cell.appendChild(ev);
        });
      }
      row.appendChild(cell);
    });

    grid.appendChild(row);
  });
}

function renderArtefacts(arr) {
  if (!Array.isArray(arr)) arr = [String(arr || "")];
  return arr.map(a => {
    const safe = escapeHtml(a);
    // Heuristique : si ça ressemble à un chemin de fichier/dossier projet
    const looksLikePath = /^[a-zA-Z0-9_]+[\/\\][^\s]+/.test(a) && !/\s—\s/.test(a);
    if (looksLikePath) {
      // Construit un computer:// vers C:\_workarea_local\aiCEO\<path>
      const cleaned = a.replace(/\s\(.+?\)$/, "").replace(/\\/g, "/");
      const winPath = "C:\\_workarea_local\\aiCEO\\" + cleaned.replace(/\//g, "\\");
      return `<a href="computer://${winPath}" class="art-link">${safe}</a>`;
    }
    return `<span class="art-item">${safe}</span>`;
  }).join("");
}

function computeDelta(m) {
  // Renvoie {days: number|null, label: string, severity: "ontime"|"early"|"late"|"unknown"}
  if (!m.planned) return { days:null, label:"—", severity:"unknown" };
  const baseline = BASELINE[m.id]?.planned || m.planned;
  if (!m.actual) {
    // jalon non encore livré → comparer planned au plan baseline si différent (drift de planning)
    if (baseline === m.planned) return { days:null, label:"planifié", severity:"unknown" };
    const d = Math.round((new Date(m.planned) - new Date(baseline)) / 86400000);
    return { days:d, label:(d>0?`+${d}j replanifié`:`${d}j avancé`), severity:(d>0?"late":"early") };
  }
  const d = Math.round((new Date(m.actual) - new Date(baseline)) / 86400000);
  if (d === 0) return { days:0, label:"à l'heure", severity:"ontime" };
  if (d < 0) return { days:d, label:`avance ${Math.abs(d)}j`, severity:"early" };
  return { days:d, label:`retard ${d}j`, severity:"late" };
}

function selectMilestone(m) {
  document.querySelectorAll(".tl-event.selected, .tl-hub-banner.selected").forEach(n => n.classList.remove("selected"));
  const el = document.querySelector(`[data-id="${m.id}"]`);
  if (el) el.classList.add("selected");
  const panel = document.getElementById("detail-panel");
  const delta = computeDelta(m);
  const sessionsHtml = (m.sessions && m.sessions.length)
    ? `<div class="sessions-list"><strong>Sessions</strong><ol>${m.sessions.map(s => `<li>${escapeHtml(s)}</li>`).join("")}</ol></div>`
    : "";
  const plannedHtml = m.planned
    ? `<div class="d-plan"><strong>Planifié</strong>${escapeHtml(m.planned)}${m.actual ? ` · livré ${escapeHtml(m.actual)}` : " · non livré"}</div>`
    : "";
  const deltaHtml = (delta.severity !== "unknown")
    ? `<div class="delta-pill delta-${delta.severity}">${escapeHtml(delta.label)}</div>`
    : "";
  panel.innerHTML = `
    <div class="meta">
      <span class="lane-badge ${m.lane}">${escapeHtml(LANE_LABEL[m.lane])}</span><br>
      <span class="pill s-${m.status}">${escapeHtml(STATUS_LABEL[m.status])}</span>
      <div class="d-date">${escapeHtml(m.date)}</div>
      ${plannedHtml}
      ${deltaHtml}
    </div>
    <div class="body">
      <h3>${escapeHtml(m.title)}</h3>
      <p>${escapeHtml(m.desc)}</p>
      ${sessionsHtml}
      <div class="artefacts"><strong>Artéfacts</strong>${renderArtefacts(m.artefacts)}</div>
      ${renderGhDetail(m.gh)}
      ${m.id === "v05-hub" ? `<button type="button" class="d-jump-cta" data-jump-tab="fusion-v05" style="margin-top:var(--space-4); padding:10px 18px; border:1px solid var(--rose); background:var(--rose-50); color:var(--rose-800); border-radius:var(--radius-xs); font-family:var(--font-sans); font-weight:var(--fw-semi); font-size:var(--fs-small); cursor:pointer;">Voir le plan détaillé v0.5 →</button>` : ""}
    </div>
  `;
  // Re-attache le handler jump-tab pour la CTA dynamique
  panel.querySelectorAll("[data-jump-tab]").forEach(b => {
    b.addEventListener("click", (e) => {
      e.preventDefault();
      activateTab(b.dataset.jumpTab);
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  });
}

function renderCounters() {
  const all = MILESTONES.concat([V05_HUB]);
  const stats = { total: all.length, done:0, doing:0, todo:0 };
  all.forEach(m => stats[m.status]++);
  const pct = Math.round((stats.done / stats.total) * 100);
  document.getElementById("counters").innerHTML = `
    <div class="counter"><div class="n">${stats.total}</div><div class="l">Jalons totaux</div></div>
    <div class="counter c-done"><div class="n">${stats.done}</div><div class="l">Fait · ${pct}%</div></div>
    <div class="counter c-doing"><div class="n">${stats.doing}</div><div class="l">En cours</div></div>
    <div class="counter c-todo"><div class="n">${stats.todo}</div><div class="l">À faire</div></div>
  `;
  document.getElementById("progress-pct").textContent = pct + "%";
  document.getElementById("progress-text").textContent = `${stats.done} / ${stats.total} jalons faits`;
  document.getElementById("progress-bar").style.width = pct + "%";
}

// ──────────────────────────────────────────────────────────────
// Filters (timeline grid)
// ──────────────────────────────────────────────────────────────

let statusFilter = "all", laneFilter = "all";
function applyFilters() {
  document.querySelectorAll(".tl-event").forEach(n => {
    const okS = statusFilter === "all" || n.dataset.status === statusFilter;
    const okL = laneFilter === "all" || n.dataset.lane === laneFilter;
    n.classList.toggle("hidden", !(okS && okL));
  });
  // hub banner
  const hub = document.querySelector(".tl-hub-banner");
  if (hub) {
    const okS = statusFilter === "all" || statusFilter === "todo";
    const okL = laneFilter === "all" || laneFilter === "hub";
    hub.style.display = (okS && okL) ? "" : "none";
  }
}
document.querySelectorAll(".filter[data-filter]").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".filter[data-filter]").forEach(b => b.setAttribute("aria-pressed", "false"));
    btn.setAttribute("aria-pressed", "true");
    statusFilter = btn.dataset.filter;
    applyFilters();
  });
});
document.querySelectorAll(".filter[data-lane]").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".filter[data-lane]").forEach(b => b.setAttribute("aria-pressed", "false"));
    btn.setAttribute("aria-pressed", "true");
    laneFilter = btn.dataset.lane;
    applyFilters();
  });
});

// ──────────────────────────────────────────────────────────────
// TAB 3 — Release notes data + render
// ──────────────────────────────────────────────────────────────

const RELEASES = [
  // ── 26/04/2026 — v0.5 internalisée TERMINÉE (tag v0.5 final, 5 sprints livrés) ──
  {
    id: "rn-mvp-0-5",
    gh: { milestone:"v0.5-s5", tag:"v0.5", branch:"main", issues:[] },
    component: "mvp",
    version: "v0.5",
    date: "26 avr. 2026",
    title: "v0.5 internalisée TERMINÉE — 5 sprints livrés, tag v0.5 final",
