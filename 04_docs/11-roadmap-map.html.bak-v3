const CAT_LABEL = { feat:"Nouveautés", improve:"Améliorations", fix:"Correctifs", perf:"Performance", breaking:"Breaking changes" };

function renderReleases() {
  const feed = document.getElementById("rn-feed");
  const toc = document.getElementById("rn-toc");
  feed.innerHTML = "";
  toc.innerHTML = "";

  const tocList = document.createElement("ol");
  toc.appendChild(tocList);

  RELEASES.forEach(r => {
    // Carte version
    const art = document.createElement("article");
    art.className = "rn-version";
    art.id = r.id;
    art.dataset.component = r.component;
    art.dataset.cats = r.changes.map(c => c.cat).join(",");
    const haystack = (r.title + " " + r.summary + " " + r.changes.flatMap(c => c.items).join(" ")).toLowerCase();
    art.dataset.text = haystack;

    const head = document.createElement("div");
    head.className = "rn-version-head";
    head.innerHTML = `
      <div>
        <span class="date">${escapeHtml(r.date)}</span>
        <h3>${escapeHtml(r.title)}</h3>
      </div>
      <span class="v-tag ${r.component}">${escapeHtml(componentLabel(r.component))} ${escapeHtml(r.version)}</span>
    `;
    art.appendChild(head);

    if (r.summary) {
      const sum = document.createElement("p");
      sum.className = "rn-summary";
      sum.innerHTML = r.summary;
      art.appendChild(sum);
    }

    const ghHtml = renderGhRef(r.gh);
    if (ghHtml) {
      const ghDiv = document.createElement("div");
      ghDiv.innerHTML = ghHtml;
      art.appendChild(ghDiv);
    }

    const changes = document.createElement("div");
    changes.className = "rn-changes";
    r.changes.forEach(c => {
      const cat = document.createElement("section");
      cat.className = `rn-cat ${c.cat}`;
      cat.dataset.cat = c.cat;
      const ul = c.items.map(i => `<li>${i}</li>`).join("");
      cat.innerHTML = `<h4 class="rn-cat-title">${escapeHtml(CAT_LABEL[c.cat] || c.cat)}</h4><ul>${ul}</ul>`;
      changes.appendChild(cat);
    });
    art.appendChild(changes);

    feed.appendChild(art);

    // TOC entry
    const li = document.createElement("li");
    li.innerHTML = `<a href="#${r.id}" data-target="${r.id}">${escapeHtml(componentLabel(r.component))} ${escapeHtml(r.version)} <span class="tag">${escapeHtml(r.date)}</span></a>`;
    tocList.appendChild(li);
  });

  // smooth scroll TOC
  document.querySelectorAll(".rn-aside .toc a").forEach(a => {
    a.addEventListener("click", (e) => {
      e.preventDefault();
      const target = document.getElementById(a.dataset.target);
      if (target) {
        target.scrollIntoView({ behavior: "smooth", block: "start" });
        document.querySelectorAll(".rn-aside .toc a").forEach(x => x.classList.remove("current"));
        a.classList.add("current");
      }
    });
  });
}

function componentLabel(c) {
  return ({ cockpit:"Cockpit", mvp:"MVP", ds:"DS Twisty", docs:"Docs", roadmap:"Roadmap", github:"GitHub" })[c] || c;
}

// Filtres release notes
let rnComp = "all", rnCat = "all", rnQuery = "";

function applyRnFilters() {
  let visibleCount = 0;
  document.querySelectorAll(".rn-version").forEach(v => {
    const okC = rnComp === "all" || v.dataset.component === rnComp;
    const cats = (v.dataset.cats || "").split(",");
    const okCat = rnCat === "all" || cats.includes(rnCat);
    const okQ = !rnQuery || (v.dataset.text || "").includes(rnQuery);
    const show = okC && okCat && okQ;
    v.classList.toggle("hidden", !show);

    // Filter categories within version
    v.querySelectorAll(".rn-cat").forEach(c => {
      if (rnCat === "all") {
        c.style.display = "";
      } else {
        c.style.display = c.dataset.cat === rnCat ? "" : "none";
      }
    });

    if (show) visibleCount++;
  });

  // Sync TOC visibility
  document.querySelectorAll(".rn-aside .toc li").forEach(li => {
    const a = li.querySelector("a");
    if (!a) return;
    const v = document.getElementById(a.dataset.target);
    li.style.display = (v && !v.classList.contains("hidden")) ? "" : "none";
  });

  // Empty state
  const feed = document.getElementById("rn-feed");
  let empty = feed.querySelector(".rn-no-results");
  if (visibleCount === 0) {
    if (!empty) {
      empty = document.createElement("div");
      empty.className = "rn-no-results";
      empty.textContent = "Aucune version ne correspond à ces filtres.";
      feed.appendChild(empty);
    }
  } else if (empty) {
    empty.remove();
  }
}

document.querySelectorAll(".rn-flt-comp").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".rn-flt-comp").forEach(b => b.setAttribute("aria-pressed", "false"));
    btn.setAttribute("aria-pressed", "true");
    rnComp = btn.dataset.comp;
    applyRnFilters();
  });
});
document.querySelectorAll(".rn-flt-cat").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".rn-flt-cat").forEach(b => b.setAttribute("aria-pressed", "false"));
    btn.setAttribute("aria-pressed", "true");
    rnCat = btn.dataset.cat;
    applyRnFilters();
  });
});

// ──────────────────────────────────────────────────────────────
// Tab switching + jump links
// ──────────────────────────────────────────────────────────────

function activateTab(tabId) {
  document.querySelectorAll(".tab").forEach(b => b.setAttribute("aria-selected", "false"));
  document.querySelectorAll(".tab-pane").forEach(p => p.classList.remove("active"));
  const btn = document.getElementById("tab-btn-" + tabId);
  const pane = document.getElementById("tab-" + tabId);
  if (btn && pane) {
    btn.setAttribute("aria-selected", "true");
    pane.classList.add("active");
  }
}

document.querySelectorAll(".tab").forEach(btn => {
  btn.addEventListener("click", () => activateTab(btn.dataset.tab));
  btn.addEventListener("keydown", (e) => {
    const tabs = Array.from(document.querySelectorAll(".tab"));
    const idx = tabs.indexOf(btn);
    if (e.key === "ArrowRight") { e.preventDefault(); tabs[(idx+1)%tabs.length].focus(); tabs[(idx+1)%tabs.length].click(); }
    if (e.key === "ArrowLeft")  { e.preventDefault(); tabs[(idx-1+tabs.length)%tabs.length].focus(); tabs[(idx-1+tabs.length)%tabs.length].click(); }
  });
});

document.querySelectorAll("[data-jump-tab]").forEach(a => {
  a.addEventListener("click", (e) => {
    e.preventDefault();
    activateTab(a.dataset.jumpTab);
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
});

// Drill-down buttons (overview tab)
document.querySelectorAll("[data-goto]").forEach(btn => {
  btn.addEventListener("click", (e) => {
    e.preventDefault();
    activateTab(btn.dataset.goto);
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
});

// Search input
document.getElementById("rn-search").addEventListener("input", (e) => {
  rnQuery = (e.target.value || "").toLowerCase().trim();
  applyRnFilters();
});

// ──────────────────────────────────────────────────────────────
// TAB 4 — Journal & écarts
// ──────────────────────────────────────────────────────────────

// Liste des jalons critiques surveillés (présents dans BASELINE)
function trackedMilestones() {
  // V05_HUB est piloté à part car il n'est pas dans MILESTONES
  const baselineKeys = Object.keys(BASELINE);
  const all = [V05_HUB, ...MILESTONES];
  return all.filter(m => baselineKeys.includes(m.id));
}

function formatDateFR(iso) {
  if (!iso) return "—";
  const d = new Date(iso);
  if (isNaN(d)) return iso;
  return d.toLocaleDateString("fr-FR", { day:"2-digit", month:"short", year:"numeric" });
}

function renderKPIs() {
  const container = document.getElementById("j-kpis");
  if (!container) return;

  const tracked = trackedMilestones();
  const drifts = tracked.map(m => ({ id:m.id, delta:computeDelta(m) }));
  const ontime = drifts.filter(d => d.delta.severity === "ontime").length;
  const early  = drifts.filter(d => d.delta.severity === "early").length;
  const late   = drifts.filter(d => d.delta.severity === "late").length;
  const critical = drifts.filter(d => d.delta.severity === "late" && d.delta.days > 3).length;
  const totalDone = MILESTONES.filter(m => m.status === "done").length;
  const totalAll  = MILESTONES.length;

  const kpis = [
    { label:"Jalons livrés",     value:`${totalDone}/${totalAll}`, sub:"périmètre carte de convergence", cls:"k-ok" },
    { label:"À l'heure",          value:String(ontime),  sub:"vs baseline atelier S4",                 cls: ontime > 0 ? "k-ok" : "k-watch" },
    { label:"En avance",          value:String(early),   sub:"jalons livrés avant date planifiée",     cls:"k-ok" },
    { label:"En dérive > 3j",     value:String(critical),sub: critical === 0 ? "rien à signaler" : "alerte active", cls: critical > 0 ? "k-warn" : (late > 0 ? "k-watch" : "k-ok") }
  ];

  container.innerHTML = kpis.map(k =>
    `<div class="j-kpi ${k.cls}">
       <span class="label">${escapeHtml(k.label)}</span>
       <span class="value">${escapeHtml(k.value)}</span>
       <span class="sub">${escapeHtml(k.sub)}</span>
     </div>`
  ).join("");
}

function renderVarianceChart() {
  const container = document.getElementById("variance-bars");
  if (!container) return;

  const tracked = trackedMilestones();
  // Échelle : ±30 jours autour de la baseline
  const SCALE = 30;
  const html = tracked.map(m => {
    const delta = computeDelta(m);
    const days = delta.days;
    const baseline = BASELINE[m.id];
    const subLabel = `BASELINE ${formatDateFR(baseline.planned)}${baseline.budget_kEUR ? ` · ${baseline.budget_kEUR} k€` : ""}`;
    const sev = delta.severity;
    let leftPct = 50;
    let widthPct = 1;
    if (days != null && !isNaN(days)) {
      const clamped = Math.max(-SCALE, Math.min(SCALE, days));
      if (clamped >= 0) {
        leftPct = 50;
        widthPct = (clamped / SCALE) * 50 || 1;
      } else {
        widthPct = (Math.abs(clamped) / SCALE) * 50 || 1;
        leftPct = 50 - widthPct;
      }
    }
    return `
      <div class="vbar-row" data-mid="${escapeHtml(m.id)}">
        <div class="vbar-label">${escapeHtml(m.title)}<small>${escapeHtml(subLabel)}</small></div>
        <div class="vbar-track" title="${escapeHtml(delta.label)}">
          <span class="vbar-fill ${escapeHtml(sev)}" style="left:${leftPct.toFixed(1)}%; width:${widthPct.toFixed(1)}%;"></span>
        </div>
        <div class="vbar-value ${escapeHtml(sev)}">${escapeHtml(delta.label)}</div>
      </div>`;
  }).join("");

  container.innerHTML = html || `<p style="color:var(--text-3); font-size:var(--fs-small);">Aucun jalon suivi dans la BASELINE.</p>`;
}

let jFilter = "all";
function renderJournalFeed() {
  const container = document.getElementById("j-feed");
  if (!container) return;

  // Tri chronologique décroissant
  const filtered = JOURNAL
    .filter(e => jFilter === "all" || e.type === jFilter)
    .slice()
    .sort((a, b) => (a.ts < b.ts ? 1 : -1));

  if (filtered.length === 0) {
    container.innerHTML = `<p style="color:var(--text-3); font-size:var(--fs-small); padding: var(--space-4);">Aucun événement pour ce filtre.</p>`;
    return;
  }

  container.innerHTML = filtered.map(e => {
    const tagColor = TYPE_COLOR[e.type] || "sky";
    const tagLabel = TYPE_LABEL[e.type] || e.type;
    const compLabel = (typeof componentLabel === "function") ? componentLabel(e.component) : e.component;
    const deltaTag = (e.delta && e.delta !== 0)
      ? `<span class="tag t-${e.delta > 0 ? "rose" : "sky"}">${e.delta > 0 ? "+" : ""}${e.delta}j</span>`
      : "";
    const srcLink = e.source ? renderJournalSource(e.source) : "";

    return `
      <article class="j-card s-${escapeHtml(e.type)}">
        <span class="when">${escapeHtml(formatDateFR(e.ts))}</span>
        <div class="body">
          <h4>${escapeHtml(e.title)}</h4>
          <p>${escapeHtml(e.detail || "")}</p>
          <div class="tags">
            <span class="tag t-${escapeHtml(tagColor)}">${escapeHtml(tagLabel)}</span>
            <span class="tag t-${escapeHtml(componentTagColor(e.component))}">${escapeHtml(compLabel)}</span>
            ${deltaTag}
          </div>
          ${srcLink}
          ${renderGhRef(e.gh)}
        </div>
      </article>`;
  }).join("");
}

function componentTagColor(c) {
  return ({ cockpit:"violet", mvp:"rose", ds:"amber", docs:"emerald", roadmap:"sky", github:"sky", hub:"amber" }[c]) || "sky";
}

function renderJournalSource(s) {
  if (!s) return "";
  const safe = escapeHtml(s);
  const looksLikePath = /^[a-zA-Z0-9_]+[\/\\][^\s]+/.test(s) && !/\s—\s/.test(s);
  if (looksLikePath) {
    const cleaned = s.replace(/\s\(.+?\)$/, "").replace(/\\/g, "/");
    const winPath = "C:\\_workarea_local\\aiCEO\\" + cleaned.replace(/\//g, "\\");
    return `<a class="src" href="computer://${winPath}">↗ ${safe}</a>`;
  }
  return `<span class="src" style="color:var(--text-3);">${safe}</span>`;
}

function renderAlertBanner() {
  const banner = document.getElementById("alert-banner");
  if (!banner) return;

  const tracked = trackedMilestones();
  const drifts = tracked.map(m => ({ id:m.id, title:m.title, delta:computeDelta(m) }));
  const critical = drifts.filter(d => d.delta.severity === "late" && d.delta.days > 3);
  const watch    = drifts.filter(d => d.delta.severity === "late" && d.delta.days > 0 && d.delta.days <= 3);
  const ontime   = drifts.filter(d => d.delta.severity === "ontime").length;

  banner.classList.remove("lvl-ok", "lvl-watch", "lvl-warn");

  let level, title, detail, icon;
  if (critical.length > 0) {
    level = "lvl-warn";
    icon = "!";
    title = `${critical.length} jalon${critical.length > 1 ? "s" : ""} en dérive critique`;
    detail = critical.map(c => `<strong>${escapeHtml(c.title)}</strong> (${escapeHtml(c.delta.label)})`).join(" · ");
  } else if (watch.length > 0) {
    level = "lvl-watch";
    icon = "~";
    title = `${watch.length} jalon${watch.length > 1 ? "s" : ""} à surveiller`;
    detail = watch.map(c => `<strong>${escapeHtml(c.title)}</strong> (${escapeHtml(c.delta.label)})`).join(" · ");
  } else {
    level = "lvl-ok";
    icon = "✓";
    title = "Tout est aligné sur la BASELINE";
    detail = `${ontime} jalon${ontime > 1 ? "s" : ""} à l'heure · BASELINE figée le 24/04/2026 (atelier S4) · prochain jalon : <strong>onboarding dev — 15 mai 2026</strong>`;
  }

  banner.classList.add(level);
  banner.querySelector(".icon").textContent = icon;
  document.getElementById("alert-title").textContent = title;
  document.getElementById("alert-detail").innerHTML = detail;
  banner.hidden = false;

  // Mise à jour du badge sur l'onglet Journal
  const badge = document.getElementById("journal-badge");
  if (badge) {
    if (critical.length > 0) { badge.textContent = `⚠ ${critical.length}`; badge.style.background = "var(--rose-50)"; badge.style.color = "var(--rose-800)"; }
    else if (watch.length > 0) { badge.textContent = `~ ${watch.length}`; badge.style.background = "var(--amber-50)"; badge.style.color = "var(--amber-800)"; }
    else { badge.textContent = "OK"; badge.style.background = "var(--emerald-50)"; badge.style.color = "var(--emerald-800)"; }
  }
}

function updateHeaderDate() {
  const versionEl = document.querySelector(".page-header .version");
  if (!versionEl) return;
  const today = new Date();
  const dd = String(today.getDate()).padStart(2, "0");
  const mm = String(today.getMonth() + 1).padStart(2, "0");
  const yyyy = today.getFullYear();
  // Conserve la version en cours (lue depuis le markup) et met à jour la date
  const match = versionEl.textContent.match(/^(v[\d.]+(?:-[a-z0-9]+)?)/i);
  const version = match ? match[1] : "v0.5-s1";
  versionEl.textContent = `${version} · ${dd}/${mm}/${yyyy}`;
}

// Filtres journal
document.querySelectorAll(".j-flt").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".j-flt").forEach(b => b.setAttribute("aria-pressed", "false"));
    btn.setAttribute("aria-pressed", "true");
    jFilter = btn.dataset.jtype;
    renderJournalFeed();
  });
});

// CTA bandeau alerte → bascule onglet journal
document.getElementById("alert-cta").addEventListener("click", () => {
  activateTab("journal");
  window.scrollTo({ top: 0, behavior: "smooth" });
});

// Init Mermaid (3 blocs ciblés)
function initMermaid() {
  if (typeof mermaid === "undefined") return;
  try {
    mermaid.initialize({
      startOnLoad: false,
      theme: "base",
      fontFamily: "Fira Sans, system-ui, sans-serif",
      themeVariables: {
        primaryColor: "#fff",
        primaryTextColor: "#324054",
        primaryBorderColor: "#7790ae",
        lineColor: "#7790ae",
        secondaryColor: "#f5e9d8",
        tertiaryColor: "#fff",
        // GitGraph theme variables
        git0: "#3d7363",
        git1: "#7a6a8a",
        git2: "#7790ae",
        git3: "#b88237",
        git4: "#d96d3e",
        git5: "#3d4e7d",
        git6: "#8a3b1b",
        git7: "#234236",
        gitBranchLabel0: "#fff",
        gitBranchLabel1: "#fff",
        gitBranchLabel2: "#fff",
        gitBranchLabel3: "#fff",
        gitBranchLabel4: "#fff",
        gitBranchLabel5: "#fff",
        commitLabelColor: "#111418",
        commitLabelBackground: "#f5f3ef",
        commitLabelFontSize: "11px",
        tagLabelColor: "#fff",
        tagLabelBackground: "#111418",
        tagLabelBorder: "#111418"
      },
      gitGraph: {
        showBranches: true,
        showCommitLabel: true,
        mainBranchName: "main"
      }
    });
    mermaid.run({ querySelector: ".mermaid" });
  } catch (e) {
    console.warn("Mermaid init failed:", e);
  }
}

// ──────────────────────────────────────────────────────────────
// Init
// ──────────────────────────────────────────────────────────────

// Charger l'état GitHub avant les renders pour enrichir les refs (issues/PRs/labels/milestones).
// Tolérant à l'absence de github-state.json (consistence-dump.ps1 non encore exécuté).
loadGhState().then(() => {
  renderTimeline();
  renderCounters();
  renderReleases();
  // Sélection initiale : dernier jalon en date (mvp-10f = pitch deck investisseur)
  selectMilestone(MILESTONES.find(m => m.id === "mvp-10f") || MILESTONES[0]);

  // Tab 4 — Journal & écarts
  updateHeaderDate();
  renderKPIs();
  renderVarianceChart();
  renderJournalFeed();
  renderAlertBanner();
});

// Mermaid : on laisse le DOM se peindre puis on initialise
if (document.readyState === "loading") {
  document.addEventListener("DOMContentLoaded", initMermaid);
} else {
  setTimeout(initMermaid, 50);
}
</script>

</body>
</html>
