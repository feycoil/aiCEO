<!doctype html>
<html lang="fr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>aiCEO — Roadmap interactive</title>
<!-- Branchement direct sur le Design System Twisty (source canonique) -->
<link rel="stylesheet" href="../02_design-system/colors_and_type.css">
<style>
/* ──────────────────────────────────────────────────────────────
   Page-specific layer — uses DS Twisty tokens (rose, amber,
   emerald, sky, violet, surface, text…) loaded above.
   No hardcoded colors. No Georgia/Calibri.
   ────────────────────────────────────────────────────────────── */

* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body { background: var(--surface); color: var(--text); margin: 0; padding: 0; min-height: 100vh; }

.wrap { max-width: 1480px; margin: 0 auto; padding: var(--space-8) var(--space-10) calc(var(--space-10) * 2); }

/* === Header === */
.page-header { display: flex; justify-content: space-between; align-items: flex-end; gap: var(--space-6); border-bottom: 1px solid var(--border); padding-bottom: var(--space-5); margin-bottom: var(--space-5); flex-wrap: wrap; }
.page-header .title h1 { margin: 0 0 4px; font-family: var(--font-sans); font-size: var(--fs-display); font-weight: var(--fw-extrabold); letter-spacing: var(--tracking-display); color: var(--text); line-height: var(--lh-tight); }
.page-header .title .subtitle { font-size: var(--fs-sm); color: var(--text-2); display: flex; align-items: baseline; gap: 6px; }
.page-header .title .subtitle .accent { font-family: var(--font-script); font-style: normal; font-size: 22px; color: var(--rose); line-height: 1; }
.page-header .meta { display: flex; flex-direction: column; align-items: flex-end; gap: 8px; }
.page-header .version { font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--text-2); background: var(--surface-2); padding: 6px 12px; border: 1px solid var(--border); border-radius: var(--radius-xs); letter-spacing: 0.02em; }
.progress-strip { background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-xs); padding: 8px 14px; display: flex; gap: 14px; align-items: center; font-size: var(--fs-tiny); color: var(--text-2); letter-spacing: 0.05em; }
.progress-strip .pct { font-family: var(--font-thin); font-size: 28px; color: var(--emerald); font-weight: var(--fw-thin); line-height: 1; }
.progress-strip .bar { width: 120px; height: 6px; background: var(--surface-3); border-radius: 99px; overflow: hidden; }
.progress-strip .bar > i { display: block; height: 100%; background: var(--emerald); border-radius: 99px; }

/* === Tabs === */
.tabs { display: flex; gap: 2px; margin-bottom: var(--space-6); border-bottom: 1px solid var(--border); padding: 0 4px; flex-wrap: wrap; }
.tab { background: transparent; border: 1px solid transparent; border-bottom: none; color: var(--text-2); padding: 12px 22px; cursor: pointer; font-family: var(--font-sans); font-size: var(--fs-h3); font-weight: var(--fw-semi); letter-spacing: -0.005em; border-radius: var(--radius-xs) var(--radius-xs) 0 0; margin-bottom: -1px; transition: color 0.15s, background 0.15s, border-color 0.15s; }
.tab:hover { color: var(--text); background: var(--surface-3); }
.tab:focus-visible { outline: none; box-shadow: var(--ring); }
.tab[aria-selected="true"] { background: var(--surface-2); color: var(--text); border-color: var(--border); border-bottom-color: var(--surface-2); }
.tab .badge { display: inline-block; margin-left: 8px; font-family: var(--font-mono); font-size: var(--fs-tiny); padding: 2px 7px; border-radius: 99px; background: var(--rose-50); color: var(--rose-800); }
.tab[aria-selected="true"] .badge { background: var(--emerald-50); color: var(--emerald-800); }
.tab-pane { display: none; }
.tab-pane.active { display: block; }

/* === Filters === */
.controls { display: flex; gap: 8px; margin-bottom: var(--space-6); flex-wrap: wrap; align-items: center; }
.controls .label { font-size: var(--fs-tiny); color: var(--text-2); letter-spacing: 0.12em; text-transform: uppercase; margin-right: 4px; }
.filter { border: 1px solid var(--border); background: var(--surface-2); color: var(--text); padding: 6px 14px; border-radius: 99px; font-size: var(--fs-xs); cursor: pointer; font-family: var(--font-sans); font-weight: var(--fw-medium); transition: all 0.15s; }
.filter:hover { border-color: var(--text-2); }
.filter:focus-visible { outline: none; box-shadow: var(--ring); }
.filter[aria-pressed="true"] { background: var(--text); color: var(--surface-2); border-color: var(--text); }
.filter.f-done[aria-pressed="true"] { background: var(--emerald); border-color: var(--emerald); }
.filter.f-doing[aria-pressed="true"] { background: var(--amber); color: var(--surface-2); border-color: var(--amber); }
.filter.f-todo[aria-pressed="true"] { background: var(--violet); color: var(--surface-2); border-color: var(--violet); }
.search { display: inline-flex; align-items: center; background: var(--surface-2); border: 1px solid var(--border); border-radius: 99px; padding: 4px 14px; font-size: var(--fs-xs); margin-left: auto; }
.search:focus-within { border-color: var(--text-2); box-shadow: var(--ring); }
.search input { border: none; background: transparent; outline: none; font-family: var(--font-sans); font-size: var(--fs-xs); color: var(--text); padding: 4px 0; min-width: 200px; }
.search .icn { color: var(--text-3); margin-right: 6px; font-family: var(--font-sans); }

/* === Convergence map — TIMELINE GRID v2 === */
.tl-card { background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 0; box-shadow: var(--shadow-sm); position: relative; overflow: hidden; }
.tl-card::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--violet) 0%, var(--violet) 30%, var(--amber) 50%, var(--rose) 70%, var(--rose-800) 100%); z-index: 2; }

.lanes-legend { display: flex; gap: var(--space-6); padding: var(--space-5) var(--space-5) 0; font-size: var(--fs-xs); flex-wrap: wrap; }
.lane-tag { display: flex; align-items: center; gap: 8px; color: var(--text-2); }
.lane-tag .swatch { width: 10px; height: 10px; border-radius: 3px; }

.tl-grid {
  display: grid;
  grid-template-columns: [time] 160px [web] 1fr [mvp] 1fr [hub] 1fr [v2] 1fr;
  margin-top: var(--space-5);
  border-top: 1px solid var(--border);
  position: relative;
}
.tl-headers { display: contents; }
.tl-headers > div {
  position: sticky; top: 0; z-index: 3;
  background: var(--surface-2);
  padding: var(--space-3) var(--space-4);
  border-bottom: 2px solid var(--border);
  border-right: 1px solid var(--border);
  font-family: var(--font-sans);
  font-size: var(--fs-tiny);
  font-weight: var(--fw-bold);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 8px;
}
.tl-headers > div:last-child { border-right: none; }
.tl-headers .h-time { color: var(--text-2); }
.tl-headers .h-web { color: var(--violet-800); }
.tl-headers .h-web::before { content: ""; width: 8px; height: 8px; border-radius: 2px; background: var(--violet); }
.tl-headers .h-mvp { color: var(--rose-800); }
.tl-headers .h-mvp::before { content: ""; width: 8px; height: 8px; border-radius: 2px; background: var(--rose); }
.tl-headers .h-hub { color: var(--amber-800); }
.tl-headers .h-hub::before { content: ""; width: 8px; height: 8px; border-radius: 2px; background: var(--amber); }
.tl-headers .h-v2 { color: var(--text); }
.tl-headers .h-v2::before { content: ""; width: 8px; height: 8px; border-radius: 2px; background: var(--text); }

.tl-row { display: contents; }
.tl-row > * { border-bottom: 1px solid var(--border); border-right: 1px solid var(--border); padding: var(--space-3) var(--space-3); min-height: 92px; }
.tl-row > *:last-child { border-right: none; }
.tl-row.now > .tl-period,
.tl-row.now > .tl-cell { background: var(--rose-50); }
.tl-row.now { position: relative; }
.tl-row.now > .tl-period::before {
  content: ""; position: absolute; left: 0; top: 0; bottom: 0;
  width: 3px; background: var(--rose);
}

.tl-period {
  background: var(--surface);
  display: flex; flex-direction: column; gap: 4px;
  font-family: var(--font-sans);
  position: relative;
}
.tl-period .month { font-weight: var(--fw-extrabold); color: var(--text); font-size: var(--fs-h3); letter-spacing: -0.01em; line-height: 1.15; }
.tl-period .sub { font-size: var(--fs-tiny); color: var(--text-2); letter-spacing: 0.04em; line-height: 1.3; }
.tl-period .now-pill { display: inline-flex; align-items: center; gap: 4px; align-self: flex-start; margin-top: 6px; padding: 3px 10px; background: var(--rose); color: var(--surface-2); border-radius: 99px; font-size: 10px; font-weight: var(--fw-bold); letter-spacing: 0.08em; text-transform: uppercase; }
.tl-period .now-pill::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: var(--surface-2); animation: pulse-dot 1.6s infinite; }
@keyframes pulse-dot { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

.tl-cell {
  display: flex; flex-direction: column; gap: 8px;
  background: var(--surface-2);
}

.tl-event {
  display: block;
  width: 100%;
  background: var(--surface-2);
  border: 1px solid var(--border);
  border-left: 3px solid var(--text-3);
  border-radius: var(--radius-xs);
  padding: 8px 10px 9px;
  text-align: left;
  cursor: pointer;
  font-family: var(--font-sans);
  transition: transform 0.12s, box-shadow 0.12s, border-color 0.12s;
  position: relative;
}
.tl-event:hover { transform: translateY(-1px); box-shadow: var(--shadow-sm); }
.tl-event:focus-visible { outline: none; box-shadow: var(--ring); }
.tl-event.web { border-left-color: var(--violet); }
.tl-event.mvp { border-left-color: var(--rose); }
.tl-event.hub { border-left-color: var(--amber); }
.tl-event.v2 { border-left-color: var(--text); }
.tl-event.s-doing { border-left-style: dashed; }
.tl-event.s-todo { border-left-style: dotted; }
.tl-event.s-todo { background: var(--surface); }
.tl-event .tle-title { font-size: var(--fs-xs); font-weight: var(--fw-bold); color: var(--text); margin: 0 0 3px; line-height: 1.3; }
.tl-event .tle-date { font-family: var(--font-mono); font-size: 10px; color: var(--text-3); letter-spacing: 0.02em; display: block; }
.tl-event .tle-status { display: inline-flex; align-items: center; gap: 4px; padding: 1px 7px; border-radius: 99px; font-size: 9px; font-weight: var(--fw-bold); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 5px; }
.tl-event.s-done .tle-status { background: var(--emerald-50); color: var(--emerald-800); }
.tl-event.s-doing .tle-status { background: var(--amber-50); color: var(--amber-800); }
.tl-event.s-todo .tle-status { background: var(--violet-50); color: var(--violet-800); }
.tl-event.s-done .tle-status::before { content: "✓"; font-weight: var(--fw-extrabold); }
.tl-event.s-doing .tle-status::before { content: "◐"; }
.tl-event.s-todo .tle-status::before { content: "○"; }
.tl-event.selected { box-shadow: var(--shadow-md); border-color: var(--text); }
.tl-event.hidden { display: none; }
.tl-cell-empty { font-size: 10px; color: var(--text-3); font-style: italic; align-self: center; opacity: 0.55; }

/* Hub banner row spans 4 lane columns */
.tl-hub-row { display: contents; }
.tl-hub-row > .tl-period { background: var(--surface); }
.tl-hub-row > .tl-hub-banner {
  grid-column: web / -1;
  background: linear-gradient(135deg, var(--amber-50) 0%, var(--rose-50) 100%);
  border-bottom: 1px solid var(--border);
  border-left: 4px solid var(--amber);
  padding: var(--space-5) var(--space-6);
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: var(--space-5);
  align-items: center;
  cursor: pointer;
  transition: box-shadow 0.15s, transform 0.12s;
  text-align: left;
  font-family: var(--font-sans);
}
.tl-hub-row > .tl-hub-banner:hover { box-shadow: var(--shadow-md); }
.tl-hub-row > .tl-hub-banner:focus-visible { outline: none; box-shadow: var(--ring); }
.tl-hub-row > .tl-hub-banner.selected { box-shadow: var(--shadow-app); border-color: var(--rose); }
.tl-hub-banner .star { width: 64px; height: 64px; border-radius: 50%; background: var(--amber); color: var(--surface-2); display: flex; align-items: center; justify-content: center; font-family: var(--font-sans); font-size: 20px; font-weight: var(--fw-extrabold); letter-spacing: -0.02em; box-shadow: 0 4px 14px rgba(184,130,55,0.35), 0 0 0 6px rgba(184,130,55,0.12); }
.tl-hub-banner h3 { margin: 0 0 4px; font-family: var(--font-sans); font-size: var(--fs-h2); font-weight: var(--fw-extrabold); color: var(--text); letter-spacing: -0.01em; }
.tl-hub-banner p { margin: 0; font-size: var(--fs-xs); color: var(--text); line-height: var(--lh-relaxed); }
.tl-hub-banner .stamp { font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--amber-800); padding: 6px 12px; background: var(--surface-2); border: 1px solid var(--amber); border-radius: var(--radius-xs); white-space: nowrap; font-weight: var(--fw-bold); }

/* Detail panel */
.detail { margin-top: var(--space-6); background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: var(--space-6); display: grid; grid-template-columns: 220px 1fr; gap: var(--space-6); min-height: 180px; box-shadow: var(--shadow-xs); }
.detail .meta { border-right: 1px solid var(--border); padding-right: var(--space-5); }
.detail .meta .pill { display: inline-block; padding: 3px 10px; border-radius: 99px; font-size: var(--fs-tiny); letter-spacing: 0.08em; text-transform: uppercase; font-weight: var(--fw-bold); margin-bottom: 8px; }
.detail .meta .pill.s-done { background: var(--emerald-50); color: var(--emerald-800); }
.detail .meta .pill.s-doing { background: var(--amber-50); color: var(--amber-800); }
.detail .meta .pill.s-todo { background: var(--violet-50); color: var(--violet-800); }
.detail .meta .lane-badge { display: inline-block; padding: 3px 10px; border-radius: var(--radius-xs); font-size: var(--fs-tiny); font-weight: var(--fw-bold); letter-spacing: 0.06em; margin-bottom: 8px; text-transform: uppercase; }
.detail .meta .lane-badge.web { background: var(--violet-50); color: var(--violet-800); }
.detail .meta .lane-badge.mvp { background: var(--rose-50); color: var(--rose-800); }
.detail .meta .lane-badge.hub { background: var(--amber-50); color: var(--amber-800); }
.detail .meta .lane-badge.v2 { background: var(--surface-3); color: var(--text); }
.detail .meta .d-date { font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--text-2); margin-top: 6px; }
.detail .body h3 { margin: 0 0 8px; font-family: var(--font-sans); font-size: var(--fs-h1); color: var(--text); font-weight: var(--fw-extrabold); letter-spacing: var(--tracking-h1); }
.detail .body p { margin: 0 0 12px; font-size: var(--fs-body); line-height: var(--lh-relaxed); color: var(--text); }
.detail .body .artefacts { font-size: var(--fs-xs); color: var(--text-2); border-top: 1px dashed var(--border); padding-top: 10px; margin-top: 12px; }
.detail .body .artefacts strong { color: var(--text); font-weight: var(--fw-bold); letter-spacing: 0.08em; text-transform: uppercase; font-size: var(--fs-tiny); display: block; margin-bottom: 4px; }
.detail .body code { background: var(--surface-3); padding: 1px 6px; border-radius: var(--radius-xs); font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--rose-800); }
.detail .empty { color: var(--text-2); font-style: italic; grid-column: 1/-1; text-align: center; padding: var(--space-10) 0; font-size: var(--fs-sm); }

/* Counters */
.counters { margin-top: var(--space-6); display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-4); }
.counter { background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: var(--space-4) var(--space-5); border-left: 4px solid var(--text-3); box-shadow: var(--shadow-xs); }
.counter.c-done { border-left-color: var(--emerald); }
.counter.c-doing { border-left-color: var(--amber); }
.counter.c-todo { border-left-color: var(--violet); }
.counter .n { font-family: var(--font-thin); font-size: 40px; font-weight: var(--fw-thin); color: var(--text); line-height: 1; letter-spacing: -0.04em; }
.counter .l { font-size: var(--fs-tiny); color: var(--text-2); letter-spacing: 0.12em; text-transform: uppercase; margin-top: 6px; font-weight: var(--fw-medium); }

/* === TAB 2 === */
.youarehere { background: linear-gradient(135deg, var(--rose-50) 0%, var(--amber-50) 100%); border: 1px solid var(--rose); border-left: 4px solid var(--rose); border-radius: var(--radius-sm); padding: var(--space-5) var(--space-6); margin-bottom: var(--space-8); display: grid; grid-template-columns: auto 1fr auto; gap: var(--space-5); align-items: center; box-shadow: var(--shadow-sm); }
.youarehere .pulse { width: 12px; height: 12px; border-radius: 50%; background: var(--rose); position: relative; box-shadow: 0 0 0 0 rgba(217,109,62,0.55); animation: pulse 2s infinite; }
@keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(217,109,62,0.55); } 70% { box-shadow: 0 0 0 14px rgba(217,109,62,0); } 100% { box-shadow: 0 0 0 0 rgba(217,109,62,0); } }
.youarehere .label { font-family: var(--font-sans); font-size: var(--fs-tiny); font-weight: var(--fw-bold); letter-spacing: 0.16em; text-transform: uppercase; color: var(--rose-800); margin-bottom: 4px; }
.youarehere h2 { margin: 0 0 4px; font-family: var(--font-sans); font-size: var(--fs-h1); font-weight: var(--fw-extrabold); color: var(--text); letter-spacing: var(--tracking-h1); }
.youarehere p { margin: 0; font-size: var(--fs-sm); color: var(--text); line-height: var(--lh-relaxed); }
.youarehere code { background: var(--surface-2); padding: 1px 6px; border-radius: var(--radius-xs); font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--rose-800); }
.youarehere .stamp { font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--text-2); padding: 6px 12px; background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-xs); white-space: nowrap; }

.section { margin-bottom: var(--space-10); }
.section-title { font-family: var(--font-sans); font-size: var(--fs-h1); color: var(--text); margin: 0 0 4px; font-weight: var(--fw-extrabold); letter-spacing: var(--tracking-h1); }
.section-sub { font-size: var(--fs-tiny); color: var(--text-2); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: var(--space-4); }

.diagram { background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: var(--space-6); box-shadow: var(--shadow-sm); }
.diagram svg { display: block; width: 100%; height: auto; }

/* Phase cards */
.phases { display: grid; grid-template-columns: repeat(5, 1fr); gap: var(--space-3); margin-top: var(--space-4); }
.phase { background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: var(--space-4) var(--space-4) var(--space-3); border-top: 4px solid var(--violet); box-shadow: var(--shadow-xs); }
.phase.next { border-top-color: var(--rose); box-shadow: 0 4px 18px rgba(217,109,62,0.15); }
.phase.doing { border-top-color: var(--rose); box-shadow: 0 4px 18px rgba(217,109,62,0.18); position: relative; }
.phase.doing::after { content: "EN COURS"; position: absolute; top: -10px; right: 12px; background: var(--rose-50); color: var(--rose-800); font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.1em; padding: 3px 8px; border-radius: 99px; border: 1px solid var(--rose); font-weight: var(--fw-bold); }
.phase.done-code { border-top-color: var(--emerald, #3d7363); }
.phase.done-code::after { content: "S1 LIVRÉ ✓"; position: absolute; top: -10px; right: 12px; background: #dff0e6; color: #1f4738; font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.1em; padding: 3px 8px; border-radius: 99px; border: 1px solid #3d7363; font-weight: var(--fw-bold); position: absolute; }
.phase.done-code { position: relative; }
.phase .phase-num { font-family: var(--font-mono); font-size: var(--fs-tiny); letter-spacing: 0.16em; color: var(--text-3); text-transform: uppercase; }
.phase .phase-name { font-family: var(--font-sans); font-size: var(--fs-h3); color: var(--text); font-weight: var(--fw-extrabold); margin: 4px 0 8px; line-height: 1.25; letter-spacing: -0.01em; }
.phase .phase-weeks { display: inline-block; font-family: var(--font-mono); font-size: var(--fs-caption); color: var(--rose-800); background: var(--rose-50); padding: 2px 8px; border-radius: 99px; margin-bottom: 10px; }
.phase .phase-lead { font-size: var(--fs-xs); line-height: var(--lh-relaxed); color: var(--text); margin: 0 0 8px; }
.phase ul { margin: 6px 0 0; padding-left: 16px; font-size: var(--fs-xs); line-height: var(--lh-relaxed); color: var(--text); }
.phase ul li { margin-bottom: 3px; }
.phase ul li::marker { color: var(--text-3); }
.phase code { font-family: var(--font-mono); font-size: 11px; color: var(--rose-800); }
.phase .deliv { margin-top: var(--space-3); padding-top: 10px; border-top: 1px dashed var(--border); font-size: var(--fs-xs); color: var(--text-2); line-height: var(--lh-relaxed); }
.phase .deliv strong { color: var(--rose-800); display: block; letter-spacing: 0.08em; text-transform: uppercase; font-size: 9px; margin-bottom: 4px; font-weight: var(--fw-bold); }

/* Pre-req cards */
.prereqs { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-3); }
.prereq { background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: var(--space-4) var(--space-5); border-left: 4px solid var(--amber); box-shadow: var(--shadow-xs); }
.prereq .n { font-family: var(--font-thin); font-size: 32px; color: var(--amber); font-weight: var(--fw-thin); line-height: 1; letter-spacing: -0.03em; }
.prereq h4 { margin: 8px 0 4px; font-family: var(--font-sans); font-size: var(--fs-h3); color: var(--text); font-weight: var(--fw-extrabold); }
.prereq p { margin: 0; font-size: var(--fs-xs); color: var(--text); line-height: var(--lh-relaxed); }
.prereq code { font-family: var(--font-mono); font-size: 11px; color: var(--rose-800); }

/* Risks */
.risks { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-3); }
.risk { background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: var(--space-4) var(--space-5); display: grid; grid-template-columns: auto 1fr; gap: var(--space-4); align-items: flex-start; box-shadow: var(--shadow-xs); }
.risk .risk-icon { width: 36px; height: 36px; border-radius: 50%; background: var(--rose-50); color: var(--rose-800); display: flex; align-items: center; justify-content: center; font-family: var(--font-sans); font-weight: var(--fw-extrabold); font-size: 16px; flex-shrink: 0; }
.risk h4 { margin: 0 0 4px; font-family: var(--font-sans); font-size: var(--fs-h3); color: var(--text); font-weight: var(--fw-extrabold); }
.risk p { margin: 0 0 6px; font-size: var(--fs-xs); color: var(--text); line-height: var(--lh-relaxed); }
.risk .mitig { font-size: var(--fs-tiny); color: var(--emerald-800); padding-top: 6px; border-top: 1px dashed var(--border); margin-top: 6px; line-height: var(--lh-relaxed); }
.risk .mitig strong { color: var(--emerald-800); letter-spacing: 0.08em; text-transform: uppercase; font-size: 9px; display: block; margin-bottom: 3px; font-weight: var(--fw-bold); }
.risk code { font-family: var(--font-mono); font-size: 11px; color: var(--rose-800); }

/* Decision banner */
.decision { background: var(--text); color: var(--surface-2); border-radius: var(--radius-sm); padding: var(--space-8) var(--space-8); margin-top: var(--space-8); text-align: center; box-shadow: var(--shadow-app); position: relative; overflow: hidden; }
.decision::before { content: ""; position: absolute; inset: 0; background: linear-gradient(135deg, transparent 30%, rgba(184,130,55,0.08) 100%); pointer-events: none; }
.decision .label { font-family: var(--font-sans); font-size: var(--fs-tiny); letter-spacing: 0.24em; text-transform: uppercase; color: var(--amber); margin-bottom: 8px; font-weight: var(--fw-bold); position: relative; }
.decision h2 { margin: 0 0 12px; font-family: var(--font-sans); font-size: var(--fs-h1); font-weight: var(--fw-extrabold); color: var(--surface-2); letter-spacing: var(--tracking-h1); position: relative; }
.decision h2 .accent { font-family: var(--font-script); font-style: normal; color: var(--amber); font-size: 28px; font-weight: var(--fw-regular); margin: 0 4px; }
.decision p { margin: 0 auto; font-size: var(--fs-sm); line-height: var(--lh-relaxed); opacity: 0.85; max-width: 860px; position: relative; }
.decision .gate { display: inline-flex; gap: var(--space-3); margin-top: var(--space-5); flex-wrap: wrap; justify-content: center; position: relative; }
.decision .gate-pill { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.18); padding: 8px 18px; border-radius: 99px; font-size: var(--fs-xs); }
.decision .gate-pill strong { color: var(--amber); font-weight: var(--fw-bold); margin-right: 4px; letter-spacing: 0.04em; }

/* === TAB 3 — Release Notes === */
.rn-layout { display: grid; grid-template-columns: 1fr 240px; gap: var(--space-8); align-items: flex-start; }
.rn-feed { display: flex; flex-direction: column; gap: var(--space-6); }
.rn-aside { position: sticky; top: var(--space-4); display: flex; flex-direction: column; gap: var(--space-4); }
.rn-aside h4 { font-family: var(--font-sans); font-size: var(--fs-tiny); letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-2); margin: 0 0 8px; font-weight: var(--fw-bold); }
.rn-aside .toc { background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: var(--space-4); box-shadow: var(--shadow-xs); }
.rn-aside .toc ol { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 4px; counter-reset: tocnum; }
.rn-aside .toc li { font-size: var(--fs-xs); }
.rn-aside .toc a { color: var(--text-2); text-decoration: none; padding: 4px 8px; display: block; border-radius: var(--radius-xs); transition: background 0.12s, color 0.12s; }
.rn-aside .toc a:hover { background: var(--surface-3); color: var(--text); }
.rn-aside .toc a.current { background: var(--rose-50); color: var(--rose-800); font-weight: var(--fw-bold); }
.rn-aside .toc .tag { font-family: var(--font-mono); font-size: 10px; color: var(--text-3); margin-left: 4px; }

.rn-intro { background: var(--surface-2); border: 1px solid var(--border); border-left: 4px solid var(--rose); border-radius: var(--radius-sm); padding: var(--space-5) var(--space-6); margin-bottom: var(--space-6); }
.rn-intro h2 { margin: 0 0 6px; font-family: var(--font-sans); font-size: var(--fs-h1); font-weight: var(--fw-extrabold); color: var(--text); letter-spacing: var(--tracking-h1); }
.rn-intro p { margin: 0; font-size: var(--fs-sm); color: var(--text); line-height: var(--lh-relaxed); }
.rn-intro code { background: var(--surface); padding: 1px 6px; border-radius: var(--radius-xs); font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--rose-800); }

.rn-version { background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: var(--space-5) var(--space-6); box-shadow: var(--shadow-xs); scroll-margin-top: 80px; }
.rn-version.hidden { display: none; }
.rn-version-head { display: grid; grid-template-columns: 1fr auto; gap: var(--space-4); align-items: baseline; padding-bottom: var(--space-3); border-bottom: 1px solid var(--border); margin-bottom: var(--space-4); flex-wrap: wrap; }
.rn-version-head .date { font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--text-2); letter-spacing: 0.04em; text-transform: uppercase; margin-bottom: 4px; display: block; }
.rn-version-head h3 { margin: 0; font-family: var(--font-sans); font-size: var(--fs-h2); font-weight: var(--fw-extrabold); color: var(--text); letter-spacing: -0.01em; }
.rn-version-head .v-tag { font-family: var(--font-mono); font-size: var(--fs-xs); padding: 4px 12px; border-radius: var(--radius-xs); white-space: nowrap; font-weight: var(--fw-bold); letter-spacing: 0.04em; }
.rn-version-head .v-tag.cockpit { background: var(--violet-50); color: var(--violet-800); border: 1px solid var(--violet); }
.rn-version-head .v-tag.mvp { background: var(--rose-50); color: var(--rose-800); border: 1px solid var(--rose); }
.rn-version-head .v-tag.ds { background: var(--amber-50); color: var(--amber-800); border: 1px solid var(--amber); }
.rn-version-head .v-tag.docs { background: var(--emerald-50); color: var(--emerald-800); border: 1px solid var(--emerald); }
.rn-version-head .v-tag.roadmap { background: var(--sky-50); color: var(--sky-800); border: 1px solid var(--sky); }
.rn-version-head .v-tag.github { background: var(--surface-3); color: var(--text); border: 1px solid var(--text-3); }

.rn-summary { font-size: var(--fs-sm); color: var(--text); line-height: var(--lh-relaxed); margin-bottom: var(--space-4); }
.rn-summary strong { font-weight: var(--fw-bold); color: var(--text); }
.rn-summary code { background: var(--surface); padding: 1px 6px; border-radius: var(--radius-xs); font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--rose-800); }

.rn-changes { display: flex; flex-direction: column; gap: var(--space-3); }
.rn-cat { padding-top: var(--space-3); border-top: 1px dashed var(--border); }
.rn-cat:first-child { border-top: none; padding-top: 0; }
.rn-cat-title { font-family: var(--font-sans); font-size: var(--fs-tiny); letter-spacing: 0.12em; text-transform: uppercase; font-weight: var(--fw-bold); margin: 0 0 8px; display: inline-flex; align-items: center; gap: 6px; }
.rn-cat-title::before { content: ""; width: 14px; height: 14px; border-radius: 50%; display: inline-block; }
.rn-cat.feat .rn-cat-title { color: var(--emerald-800); }
.rn-cat.feat .rn-cat-title::before { background: var(--emerald); }
.rn-cat.improve .rn-cat-title { color: var(--sky-800); }
.rn-cat.improve .rn-cat-title::before { background: var(--sky); }
.rn-cat.fix .rn-cat-title { color: var(--rose-800); }
.rn-cat.fix .rn-cat-title::before { background: var(--rose); }
.rn-cat.perf .rn-cat-title { color: var(--violet-800); }
.rn-cat.perf .rn-cat-title::before { background: var(--violet); }
.rn-cat.breaking .rn-cat-title { color: var(--text); }
.rn-cat.breaking .rn-cat-title::before { background: var(--text); }
.rn-cat ul { margin: 0; padding-left: 20px; font-size: var(--fs-sm); line-height: var(--lh-relaxed); color: var(--text); }
.rn-cat ul li { margin-bottom: 4px; }
.rn-cat ul li::marker { color: var(--text-3); }
.rn-cat ul li code { background: var(--surface); padding: 1px 6px; border-radius: var(--radius-xs); font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--rose-800); }
.rn-cat ul li strong { color: var(--text); font-weight: var(--fw-bold); }

.rn-no-results { text-align: center; padding: var(--space-10); color: var(--text-2); font-style: italic; font-size: var(--fs-sm); background: var(--surface-2); border: 1px dashed var(--border); border-radius: var(--radius-sm); }

/* Footer */
footer { margin-top: var(--space-10); padding-top: var(--space-5); border-top: 1px solid var(--border); text-align: center; font-size: var(--fs-tiny); color: var(--text-3); letter-spacing: 0.08em; }
footer code { font-family: var(--font-mono); color: var(--text-2); }
footer strong { color: var(--text); font-weight: var(--fw-bold); }

/* Sr-only */
.sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }

/* Responsive */
@media (max-width: 1180px) {
  .tl-grid { grid-template-columns: [time] 130px [web] 1fr [mvp] 1fr [hub] 1fr [v2] 1fr; }
  .rn-layout { grid-template-columns: 1fr; }
  .rn-aside { position: static; order: -1; }
  .rn-aside .toc { max-height: 240px; overflow-y: auto; }
}
@media (max-width: 1100px) {
  .phases, .prereqs { grid-template-columns: repeat(2, 1fr); }
  .risks { grid-template-columns: 1fr; }
  .counters { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 900px) {
  .tl-card { overflow-x: auto; }
  .tl-grid { min-width: 760px; }
}
@media (max-width: 720px) {
  .wrap { padding: var(--space-5) var(--space-4) var(--space-8); }
  .page-header { gap: var(--space-3); }
  .page-header .meta { align-items: flex-start; flex-direction: row; flex-wrap: wrap; }
  .phases, .prereqs { grid-template-columns: 1fr; }
  .detail { grid-template-columns: 1fr; }
  .detail .meta { border-right: none; border-bottom: 1px solid var(--border); padding-right: 0; padding-bottom: var(--space-4); }
  .youarehere { grid-template-columns: 1fr; }
  .youarehere .stamp { justify-self: start; }
  .rn-version-head { grid-template-columns: 1fr; }
  .tl-hub-row > .tl-hub-banner { grid-template-columns: 1fr; gap: var(--space-3); }
}

/* ==================================================================
   TAB 4 — Journal & écarts
   ================================================================== */

/* Delta pills (used in detail panel + journal feed) */
.delta-pill { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 99px; font-family: var(--font-mono); font-size: var(--fs-tiny); font-weight: var(--fw-bold); letter-spacing: 0.04em; margin-top: 6px; }
.delta-pill::before { content: ""; width: 7px; height: 7px; border-radius: 50%; }
.delta-pill.delta-ontime   { background: var(--emerald-50); color: var(--emerald-800); }
.delta-pill.delta-ontime::before   { background: var(--emerald-800); }
.delta-pill.delta-early    { background: var(--sky-50); color: var(--sky-800); }
.delta-pill.delta-early::before    { background: var(--sky-800); }
.delta-pill.delta-late     { background: var(--rose-50); color: var(--rose-800); }
.delta-pill.delta-late::before     { background: var(--rose-800); }
.delta-pill.delta-unknown  { background: var(--surface-3); color: var(--text-3); }
.delta-pill.delta-unknown::before  { background: var(--text-3); }

/* Sessions list inside detail panel (web-07) */
.sessions-list { margin-top: var(--space-3); padding-top: var(--space-3); border-top: 1px dashed var(--border); }
.sessions-list strong { display: block; font-size: var(--fs-small); color: var(--text-2); letter-spacing: 0.04em; text-transform: uppercase; margin-bottom: 6px; font-weight: var(--fw-bold); }
.sessions-list ol { margin: 0; padding-left: 1.2em; color: var(--text-2); font-size: var(--fs-small); line-height: 1.55; }
.sessions-list ol li { margin: 2px 0; }

/* Planned vs actual block */
.d-plan { margin-top: var(--space-2); font-size: var(--fs-tiny); color: var(--text-3); font-family: var(--font-mono); }
.d-plan strong { display: inline-block; min-width: 70px; color: var(--text-2); margin-right: 6px; }

/* Artefact list — clickable file paths vs plain labels */
.artefacts { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
.art-link, .art-item { display: inline-flex; align-items: center; padding: 4px 10px; border-radius: var(--radius-xs); font-family: var(--font-mono); font-size: var(--fs-tiny); border: 1px solid var(--border); background: var(--surface-2); color: var(--text-2); text-decoration: none; }
.art-link { color: var(--sky-800); border-color: var(--sky-50); }
.art-link:hover { background: var(--sky-50); color: var(--sky-800); border-color: var(--sky-800); }
.art-item { color: var(--text-3); font-style: italic; }

/* Global alert banner (visible above tabs when drift detected) */
.alert-banner { margin: 0 0 var(--space-5); border-radius: var(--radius-md); padding: var(--space-4) var(--space-5); display: grid; grid-template-columns: 44px 1fr auto; gap: var(--space-4); align-items: center; box-shadow: var(--shadow-sm); border: 1px solid; }
.alert-banner.lvl-ok    { background: var(--emerald-50); border-color: var(--emerald-800); color: var(--emerald-800); }
.alert-banner.lvl-watch { background: var(--amber-50); border-color: var(--amber-800); color: var(--amber-800); }
.alert-banner.lvl-warn  { background: var(--rose-50); border-color: var(--rose-800); color: var(--rose-800); }
.alert-banner .icon { width: 44px; height: 44px; border-radius: 50%; display: grid; place-items: center; font-family: var(--font-mono); font-size: 22px; font-weight: var(--fw-bold); background: rgba(255,255,255,0.5); }
.alert-banner .body h3 { margin: 0 0 4px; font-size: var(--fs-h3); font-weight: var(--fw-bold); letter-spacing: -0.01em; }
.alert-banner .body p { margin: 0; font-size: var(--fs-body); line-height: 1.5; opacity: 0.92; }
.alert-banner .body p strong { font-weight: var(--fw-bold); }
.alert-banner .cta { background: rgba(255,255,255,0.7); border: 1px solid currentColor; color: inherit; padding: 8px 14px; border-radius: var(--radius-xs); font-family: var(--font-sans); font-weight: var(--fw-semi); font-size: var(--fs-small); cursor: pointer; transition: background 0.15s; }
.alert-banner .cta:hover { background: rgba(255,255,255,1); }

/* Tab 4 — Journal layout */
.j-intro { margin-bottom: var(--space-6); }
.j-intro h2 { font-family: var(--font-sans); font-weight: var(--fw-bold); font-size: var(--fs-h2); margin: 0 0 var(--space-2); letter-spacing: -0.015em; }
.j-intro p { margin: 0; color: var(--text-2); font-size: var(--fs-body); line-height: 1.55; }

/* KPI strip — quick health snapshot */
.j-kpis { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-3); margin-bottom: var(--space-6); }
.j-kpi { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); padding: var(--space-4); display: flex; flex-direction: column; gap: 4px; box-shadow: var(--shadow-xs); }
.j-kpi .label { font-size: var(--fs-tiny); color: var(--text-3); text-transform: uppercase; letter-spacing: 0.06em; font-weight: var(--fw-semi); }
.j-kpi .value { font-family: var(--font-thin); font-size: 36px; line-height: 1; font-weight: var(--fw-bold); letter-spacing: -0.025em; }
.j-kpi.k-ok    .value { color: var(--emerald-800); }
.j-kpi.k-watch .value { color: var(--amber-800); }
.j-kpi.k-warn  .value { color: var(--rose-800); }
.j-kpi .sub { font-size: var(--fs-tiny); color: var(--text-3); }

/* Variance chart (jalons critiques avec dérive en jours) */
.j-chart { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); padding: var(--space-5); margin-bottom: var(--space-6); box-shadow: var(--shadow-xs); }
.j-chart h3 { margin: 0 0 var(--space-2); font-size: var(--fs-h3); font-weight: var(--fw-bold); letter-spacing: -0.005em; }
.j-chart .hint { margin: 0 0 var(--space-4); font-size: var(--fs-small); color: var(--text-3); }
.variance-bars { display: flex; flex-direction: column; gap: 10px; }
.vbar-row { display: grid; grid-template-columns: 220px 1fr 90px; gap: var(--space-3); align-items: center; }
.vbar-label { font-size: var(--fs-small); color: var(--text-2); font-weight: var(--fw-semi); }
.vbar-label small { display: block; font-size: var(--fs-tiny); color: var(--text-3); font-weight: var(--fw-regular); margin-top: 2px; }
.vbar-track { position: relative; height: 22px; background: var(--surface-2); border-radius: var(--radius-xs); overflow: hidden; border: 1px solid var(--border); }
.vbar-track::before { content: ""; position: absolute; left: 50%; top: 0; bottom: 0; width: 1px; background: var(--text-3); opacity: 0.4; }
.vbar-fill { position: absolute; top: 2px; bottom: 2px; border-radius: 2px; }
.vbar-fill.early { background: var(--sky-800); }
.vbar-fill.ontime { background: var(--emerald-800); }
.vbar-fill.late { background: var(--rose-800); }
.vbar-fill.unknown { background: var(--text-3); opacity: 0.5; }
.vbar-value { font-family: var(--font-mono); font-size: var(--fs-small); font-weight: var(--fw-bold); text-align: right; }
.vbar-value.early { color: var(--sky-800); }
.vbar-value.ontime { color: var(--emerald-800); }
.vbar-value.late { color: var(--rose-800); }
.vbar-value.unknown { color: var(--text-3); }

/* Journal feed — chronological */
.j-feed { display: flex; flex-direction: column; gap: var(--space-3); }
.j-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); padding: var(--space-4) var(--space-5); display: grid; grid-template-columns: 110px 1fr; gap: var(--space-4); box-shadow: var(--shadow-xs); }
.j-card .when { font-family: var(--font-mono); font-size: var(--fs-small); color: var(--text-3); font-weight: var(--fw-semi); padding-top: 2px; }
.j-card .body h4 { margin: 0 0 4px; font-size: var(--fs-body); font-weight: var(--fw-bold); letter-spacing: -0.005em; }
.j-card .body p { margin: 0; font-size: var(--fs-small); color: var(--text-2); line-height: 1.55; }
.j-card .tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
.j-card .tag { display: inline-block; padding: 2px 9px; border-radius: 99px; font-family: var(--font-mono); font-size: var(--fs-tiny); font-weight: var(--fw-semi); letter-spacing: 0.04em; }
.j-card .tag.t-emerald { background: var(--emerald-50); color: var(--emerald-800); }
.j-card .tag.t-sky     { background: var(--sky-50);     color: var(--sky-800); }
.j-card .tag.t-amber   { background: var(--amber-50);   color: var(--amber-800); }
.j-card .tag.t-rose    { background: var(--rose-50);    color: var(--rose-800); }
.j-card .tag.t-violet  { background: var(--violet-50);  color: var(--violet-800); }
.j-card.s-livraison    { border-left: 4px solid var(--emerald-800); }
.j-card.s-décision     { border-left: 4px solid var(--sky-800); }
.j-card.s-écart        { border-left: 4px solid var(--amber-800); }
.j-card.s-dérive       { border-left: 4px solid var(--rose-800); }
.j-card.s-ajout-hors-plan { border-left: 4px solid var(--violet-800); }
.j-card .src { display: inline-block; margin-top: 8px; font-family: var(--font-mono); font-size: var(--fs-tiny); color: var(--sky-800); text-decoration: none; padding: 3px 8px; border-radius: var(--radius-xs); border: 1px solid var(--sky-50); background: var(--surface-2); }
.j-card .src:hover { background: var(--sky-50); }

/* Filters for journal */
.j-filters { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; margin-bottom: var(--space-5); padding: var(--space-3) var(--space-4); background: var(--surface-2); border-radius: var(--radius-md); border: 1px solid var(--border); }
.j-filters .label { font-size: var(--fs-tiny); color: var(--text-3); text-transform: uppercase; letter-spacing: 0.06em; font-weight: var(--fw-semi); margin-right: 4px; }

/* Mermaid blocs */
.j-mermaid-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-5); margin-bottom: var(--space-6); }
.j-mermaid { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); padding: var(--space-5); box-shadow: var(--shadow-xs); }
.j-mermaid h3 { margin: 0 0 var(--space-2); font-size: var(--fs-h3); font-weight: var(--fw-bold); letter-spacing: -0.005em; }
.j-mermaid .hint { margin: 0 0 var(--space-4); font-size: var(--fs-small); color: var(--text-3); }
.j-mermaid .mermaid { font-family: var(--font-sans); display: flex; justify-content: center; }

/* Responsive */
@media (max-width: 1100px) {
  .j-kpis { grid-template-columns: repeat(2, 1fr); }
  .vbar-row { grid-template-columns: 160px 1fr 70px; }
}
@media (max-width: 720px) {
  .alert-banner { grid-template-columns: 36px 1fr; }
  .alert-banner .cta { grid-column: 1 / -1; }
  .j-card { grid-template-columns: 1fr; }
  .j-card .when { padding-top: 0; }
  .vbar-row { grid-template-columns: 1fr; gap: 6px; }
  .vbar-track { height: 18px; }
  .vbar-value { text-align: left; }
}

/* ──────────────────────────────────────────────────────────────
 * GitHub references (issues, PRs, milestones) — style natif GH
 * ────────────────────────────────────────────────────────────── */
.gh-refs { display: flex; flex-wrap: wrap; gap: 8px 10px; align-items: center;
           margin-top: var(--space-3); padding-top: var(--space-3);
           border-top: 1px dashed color-mix(in srgb, var(--text-3) 30%, transparent); }
.gh-refs.compact { margin-top: 6px; padding-top: 0; border-top: none; }
.gh-refs-empty { color: var(--text-3); font-style: italic; font-size: var(--fs-small); }
.gh-refs-loading { color: var(--text-3); font-size: var(--fs-small); }
.gh-refs-stale  { color: #b45309; font-size: var(--fs-small); }

.gh-ref { display: inline-flex; align-items: center; gap: 6px;
          padding: 3px 10px 3px 8px; border-radius: 999px;
          background: #f6f8fa; color: #1f2328;
          font-family: var(--font-sans); font-size: 12px; line-height: 1.4;
          text-decoration: none; border: 1px solid #d0d7de;
          transition: background .12s; white-space: nowrap; }
.gh-ref:hover { background: #eaeef2; text-decoration: none; }
.gh-ref .gh-icon { width: 14px; height: 14px; flex-shrink: 0; }
.gh-ref .gh-num { font-weight: 600; color: #57606a; font-variant-numeric: tabular-nums; }
.gh-ref .gh-title { color: #1f2328; max-width: 280px; overflow: hidden;
                    text-overflow: ellipsis; }

/* state badges (couleurs GH officielles) */
.gh-state { display: inline-flex; align-items: center; gap: 4px;
            padding: 2px 7px; border-radius: 999px;
            font-size: 11px; font-weight: 600; line-height: 1.4;
            color: #fff; }
.gh-state.open    { background: #1a7f37; }   /* GH "Open" green */
.gh-state.closed  { background: #8250df; }   /* GH "Closed (completed)" purple */
.gh-state.notplanned { background: #6e7781; } /* GH "Closed (not planned)" gray */
.gh-state.merged  { background: #8250df; }   /* GH "Merged" purple */
.gh-state.draft   { background: #6e7781; }   /* GH "Draft" gray */

/* labels (GitHub-style colored pills, contrast auto) */
.gh-label { display: inline-block; padding: 1px 8px; border-radius: 999px;
            font-size: 11px; line-height: 1.5; font-weight: 500;
            border: 1px solid color-mix(in srgb, var(--gh-bg) 80%, black);
            background: var(--gh-bg); color: var(--gh-fg); }

/* milestone */
.gh-milestone { display: inline-flex; align-items: center; gap: 4px;
                padding: 2px 8px; border-radius: 999px;
                background: #ddf4ff; color: #0969da;
                font-size: 11px; line-height: 1.5; }
.gh-milestone.closed { background: #e7e1ff; color: #6639ba; }

/* assignees / reviewers */
.gh-people { display: inline-flex; align-items: center; gap: 3px; }
.gh-people .gh-label-mini { font-size: 10px; color: #57606a; margin-right: 4px;
                            text-transform: uppercase; letter-spacing: 0.04em; }
.gh-avatar { display: inline-flex; align-items: center; justify-content: center;
             width: 20px; height: 20px; border-radius: 50%;
             background: color-mix(in srgb, var(--rose) 25%, var(--surface-2));
             color: var(--text-1); font-size: 10px; font-weight: 600;
             border: 1px solid var(--surface-3);
             text-transform: uppercase; }
.gh-avatar.reviewer { background: color-mix(in srgb, var(--emerald) 30%, var(--surface-2)); }
.gh-avatar.reviewer.changes_requested { background: color-mix(in srgb, var(--rose) 40%, var(--surface-2)); }
.gh-avatar.reviewer.commented { background: color-mix(in srgb, var(--amber) 30%, var(--surface-2)); }

/* branch chip */
.gh-branch { display: inline-flex; align-items: center; gap: 4px;
             padding: 2px 8px; border-radius: 999px;
             background: var(--surface-2); color: var(--text-2);
             font-family: var(--font-mono, monospace); font-size: 11px; }
.gh-branch::before { content: "⌥"; opacity: 0.6; }

/* tag chip */
.gh-tag { display: inline-flex; align-items: center; gap: 4px;
          padding: 2px 8px; border-radius: 999px;
          background: #fff8c5; color: #633c01;
          font-family: var(--font-mono, monospace); font-size: 11px; border: 1px solid #d4a72c40; }
.gh-tag::before { content: "🏷"; }

/* commit chip */
.gh-commit { display: inline-flex; align-items: center; gap: 4px;
             padding: 2px 8px; border-radius: 999px;
             background: var(--surface-2); color: var(--text-2);
             font-family: var(--font-mono, monospace); font-size: 11px; }
.gh-commit::before { content: "⎇"; opacity: 0.6; }

/* full GH detail block (used in milestone drawer) */
.gh-detail { margin-top: var(--space-3); padding: var(--space-3) var(--space-3);
             background: #f6f8fa; border: 1px solid #d0d7de;
             border-radius: var(--radius-xs); }
.gh-detail h5 { margin: 0 0 8px 0; font-size: 12px; text-transform: uppercase;
                letter-spacing: 0.05em; color: #57606a; font-weight: 600; }
.gh-detail .gh-row { display: flex; flex-wrap: wrap; gap: 6px 8px;
                     align-items: center; margin-bottom: 6px; }
.gh-detail .gh-row:last-child { margin-bottom: 0; }
.gh-detail .gh-row-label { font-size: 11px; color: #57606a;
                            text-transform: uppercase; letter-spacing: 0.04em;
                            min-width: 80px; }

/* ════════════════════════════════════════════════════════════════
   NOUVEAU TAB v2 — Vue d'ensemble (overview) + V1 → V3
   ════════════════════════════════════════════════════════════════ */
.ov-kpis { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-4); margin-bottom: var(--space-8); }
.ov-kpi { background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: var(--space-5); display: flex; flex-direction: column; gap: 4px; position: relative; transition: transform .15s, box-shadow .15s; }
.ov-kpi:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
.ov-kpi-icon { position: absolute; top: 12px; right: 12px; width: 28px; height: 28px; border-radius: 50%; display: grid; place-items: center; background: var(--surface-3); color: var(--text-2); font-size: 14px; font-weight: var(--fw-bold); }
.ov-kpi-val { font-family: var(--font-thin); font-size: 44px; font-weight: var(--fw-thin); letter-spacing: -0.04em; line-height: 1; color: var(--text); font-variant-numeric: tabular-nums; }
.ov-kpi-unit { font-size: 22px; font-weight: var(--fw-light); color: var(--text-2); margin-left: 2px; }
.ov-kpi-lbl { font-size: var(--fs-xs); font-weight: var(--fw-bold); color: var(--text); text-transform: uppercase; letter-spacing: 0.06em; margin-top: 4px; }
.ov-kpi-sub { font-size: var(--fs-tiny); color: var(--text-3); line-height: 1.4; }
.ov-kpi--big { grid-column: span 2; background: var(--emerald-50); border-color: var(--emerald); border-width: 2px; }
.ov-kpi--big .ov-kpi-icon { background: var(--emerald); color: #fff; }
.ov-kpi--big .ov-kpi-val { color: var(--emerald-800); }
.ov-kpi--big .ov-kpi-lbl { color: var(--emerald-800); }
.ov-kpi--big .ov-kpi-sub { color: var(--emerald-800); }
.ov-kpi--next { background: var(--rose-50); border-color: var(--rose); border-width: 2px; }
.ov-kpi--next .ov-kpi-icon { background: var(--rose); color: #fff; }
.ov-kpi--next .ov-kpi-val { color: var(--rose-800); }
.ov-kpi--next .ov-kpi-lbl { color: var(--rose-800); }
.ov-kpi--next .ov-kpi-sub { color: var(--rose-800); }
.ov-section { margin-bottom: var(--space-8); }
.ov-section-title { font-family: var(--font-sans); font-size: var(--fs-h2); font-weight: var(--fw-extrabold); letter-spacing: -0.01em; margin: 0 0 8px; color: var(--text); }
.ov-section-sub { font-size: var(--fs-sm); color: var(--text-2); margin: 0 0 var(--space-5); line-height: 1.5; }
.ov-gitgraph { background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: var(--space-6); overflow-x: auto; box-shadow: var(--shadow-sm); }
.ov-gitgraph .mermaid { font-family: var(--font-sans); }
.ov-gitgraph-legend { display: flex; gap: var(--space-5); margin-top: var(--space-4); font-size: var(--fs-xs); color: var(--text-2); flex-wrap: wrap; justify-content: center; }
.ov-leg { display: flex; align-items: center; gap: 6px; }
.ov-leg-dot { width: 10px; height: 10px; border-radius: 50%; }
.ov-leg--done .ov-leg-dot { background: var(--emerald); }
.ov-leg--current .ov-leg-dot { background: var(--rose); box-shadow: 0 0 0 3px var(--rose-50); }
.ov-leg--todo .ov-leg-dot { background: var(--violet); }
.ov-next { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4); margin-bottom: var(--space-8); }
.ov-next-block { background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: var(--space-5); border-left: 4px solid var(--text-3); }
.ov-next-block--current { border-left-color: var(--emerald); background: var(--emerald-50); }
.ov-next-block--soon { border-left-color: var(--rose); background: var(--rose-50); }
.ov-next-block--decision { border-left-color: var(--amber); background: var(--amber-50); }
.ov-next-tag { font-size: var(--fs-tiny); font-weight: var(--fw-bold); text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-2); margin-bottom: 8px; }
.ov-next-block--current .ov-next-tag { color: var(--emerald-800); }
.ov-next-block--soon .ov-next-tag { color: var(--rose-800); }
.ov-next-block--decision .ov-next-tag { color: var(--amber-800); }
.ov-next-title { font-size: var(--fs-h3); font-weight: var(--fw-bold); letter-spacing: -0.005em; margin-bottom: 8px; line-height: 1.3; color: var(--text); }
.ov-next-detail { font-size: var(--fs-sm); color: var(--text-2); line-height: 1.5; }
.ov-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-3); }
.ov-link { display: flex; align-items: flex-start; gap: var(--space-3); padding: var(--space-4); background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-sm); cursor: pointer; text-align: left; font-family: inherit; transition: all .15s; }
.ov-link:hover { border-color: var(--text-2); transform: translateY(-1px); box-shadow: var(--shadow-sm); }
.ov-link:focus-visible { outline: none; box-shadow: var(--ring); }
.ov-link-icon { width: 32px; height: 32px; border-radius: var(--radius-xs); background: var(--surface-3); color: var(--text); display: grid; place-items: center; font-size: 16px; font-weight: var(--fw-bold); flex-shrink: 0; }
.ov-link-content { display: flex; flex-direction: column; gap: 2px; }
.ov-link-title { font-size: var(--fs-sm); font-weight: var(--fw-bold); color: var(--text); }
.ov-link-sub { font-size: var(--fs-tiny); color: var(--text-3); line-height: 1.4; }
.v1-themes { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-4); margin-bottom: var(--space-6); }
.v1-theme { display: flex; gap: var(--space-4); padding: var(--space-5); background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-sm); }
.v1-theme-num { width: 36px; height: 36px; border-radius: 50%; background: var(--text); color: #fff; display: grid; place-items: center; font-weight: var(--fw-extrabold); font-size: var(--fs-h3); flex-shrink: 0; }
.v1-theme-content { flex: 1; }
.v1-theme-title { font-size: var(--fs-h3); font-weight: var(--fw-bold); letter-spacing: -0.005em; margin-bottom: 4px; color: var(--text); }
.v1-theme-budget { font-size: var(--fs-tiny); font-weight: var(--fw-bold); text-transform: uppercase; letter-spacing: 0.06em; color: var(--rose-800); margin-bottom: 8px; }
.v1-theme-detail { font-size: var(--fs-sm); color: var(--text-2); line-height: 1.5; }
.v1-budget { background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: var(--space-6); }
.v1-budget-title { font-size: var(--fs-h3); font-weight: var(--fw-extrabold); margin-bottom: var(--space-4); color: var(--text); }
.v1-budget-table { width: 100%; border-collapse: collapse; font-size: var(--fs-sm); font-variant-numeric: tabular-nums; }
.v1-budget-table td, .v1-budget-table th { padding: 10px 12px; border-bottom: 1px solid var(--border); text-align: left; }
.v1-budget-table th { font-weight: var(--fw-bold); font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-2); }
.v1-budget-table td:last-child, .v1-budget-table th:last-child { text-align: right; }
.v1-budget-table .v1-budget-total td { font-weight: var(--fw-bold); border-top: 2px solid var(--text); border-bottom: none; padding-top: 14px; font-size: var(--fs-h3); }
.v1-budget-saving { margin-top: var(--space-4); padding: var(--space-3) var(--space-4); background: var(--emerald-50); border-left: 3px solid var(--emerald); border-radius: var(--radius-xs); font-size: var(--fs-sm); color: var(--emerald-800); }
.v2-features { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-3); }
.v2-feat { padding: var(--space-3) var(--space-4); background: var(--surface-2); border: 1px solid var(--border); border-radius: var(--radius-sm); font-size: var(--fs-sm); color: var(--text); line-height: 1.5; }
@media (max-width: 1024px) {
  .ov-kpis { grid-template-columns: repeat(2, 1fr); }
  .ov-kpi--big { grid-column: span 2; }
  .ov-next { grid-template-columns: 1fr; }
  .v1-themes { grid-template-columns: 1fr; }
}
@media (max-width: 640px) {
  .ov-kpis { grid-template-columns: 1fr; }
  .ov-kpi--big { grid-column: span 1; }
  .ov-kpi-val { font-size: 36px; }
}

/* Vue executive — bandeau résumé une ligne */
.ov-exec-summary {
  background: linear-gradient(135deg, var(--surface-2) 0%, var(--surface-3) 100%);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: var(--space-4) var(--space-5);
  margin-bottom: var(--space-4);
  box-shadow: var(--shadow-sm);
}
.ov-exec-line {
  margin: 0;
  font-size: var(--fs-h3);
  font-weight: var(--fw-medium);
  color: var(--text);
  line-height: 1.5;
  font-variant-numeric: tabular-nums;
}
.ov-exec-line strong { font-weight: var(--fw-extrabold); color: var(--text); }
.ov-exec-sep { color: var(--text-3); font-weight: var(--fw-light); margin: 0 4px; }

/* KPIs allégés en mode exec — 4 colonnes au lieu de 4×2 */
.ov-kpis--exec {
  grid-template-columns: 1.5fr 1fr 1.5fr 1fr;
}
@media (max-width: 1024px) {
  .ov-kpis--exec { grid-template-columns: 1fr 1fr; }
  .ov-kpis--exec .ov-kpi--big { grid-column: span 2; }
}
@media (max-width: 640px) {
  .ov-kpis--exec { grid-template-columns: 1fr; }
  .ov-kpis--exec .ov-kpi--big { grid-column: span 1; }
}

/* Trajectoire — vue par palier */
.traj-paliers { display: grid; grid-template-columns: 1fr; gap: var(--space-3); }
.traj-palier {
  background: var(--surface-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: var(--space-4) var(--space-5);
  border-left: 4px solid var(--text-3);
  transition: border-left-color .15s, box-shadow .15s;
}
.traj-palier:hover { box-shadow: var(--shadow-sm); }
.traj-palier--done { border-left-color: var(--emerald); background: linear-gradient(90deg, rgba(61,115,99,0.04) 0%, var(--surface-2) 30%); }
.traj-palier--soon { border-left-color: var(--rose); background: linear-gradient(90deg, rgba(217,109,62,0.04) 0%, var(--surface-2) 30%); }
.traj-palier--later { border-left-color: var(--violet); background: linear-gradient(90deg, rgba(122,106,138,0.04) 0%, var(--surface-2) 30%); }
.traj-palier-tag {
  display: inline-block;
  font-size: var(--fs-tiny);
  font-weight: var(--fw-bold);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-2);
  margin-bottom: 6px;
}
.traj-palier--done .traj-palier-tag { color: var(--emerald-800); }
.traj-palier--soon .traj-palier-tag { color: var(--rose-800); }
.traj-palier--later .traj-palier-tag { color: var(--violet-800); }
.traj-palier-title { font-size: var(--fs-h3); margin-bottom: 4px; color: var(--text); line-height: 1.3; }
.traj-palier-meta { font-size: var(--fs-xs); color: var(--text-2); margin-bottom: 8px; font-variant-numeric: tabular-nums; }
.traj-palier-detail { font-size: var(--fs-sm); color: var(--text-2); line-height: 1.55; }

.traj-budget-summary {
  margin-top: var(--space-5);
  padding: var(--space-4) var(--space-5);
  background: linear-gradient(135deg, var(--surface-3) 0%, var(--surface-2) 100%);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  font-size: var(--fs-sm);
  color: var(--text);
  font-variant-numeric: tabular-nums;
}

</style>
<!-- Mermaid pour les 3 blocs ciblés (architecture / dépendances / ADR) -->
<script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
</head>
<body>
<div class="wrap">

  <header class="page-header">
    <div class="title">
      <h1>Roadmap produit aiCEO</h1>
      <div class="subtitle"><span class="accent">Carte</span>de convergence · App Web + MVP → v0.5 fusion → V1 → V2 → V3</div>
    </div>
    <div class="meta">
      <div class="progress-strip" aria-label="Progression globale des jalons">
        <span>Avancement</span>
        <span class="pct" id="progress-pct">—</span>
        <span class="bar" aria-hidden="true"><i id="progress-bar" style="width:0%"></i></span>
        <span id="progress-text">— jalons faits</span>
      </div>
      <div class="version">v0.5 LIVRÉ · v0.6 EN COURS S6.1 · 26/04/2026 · binôme CEO+Claude</div>
    </div>
  </header>

  <!-- Bandeau global d'alerte écart — calculé dynamiquement vs BASELINE -->
  <div id="alert-banner" class="alert-banner" hidden>
    <div class="icon" aria-hidden="true">!</div>
    <div class="body">
      <h3 id="alert-title">Tout est aligné</h3>
      <p id="alert-detail">Aucun écart significatif détecté.</p>
    </div>
    <button class="cta" id="alert-cta" type="button">Voir le détail</button>
  </div>

  <nav class="tabs" role="tablist" aria-label="Vues de la roadmap">
    <button class="tab" data-tab="overview" role="tab" aria-selected="true" aria-controls="tab-overview" id="tab-btn-overview">Vue d'ensemble <span class="badge">v0.5 ✓</span></button>
    <button class="tab" data-tab="v06" role="tab" aria-selected="false" aria-controls="tab-v06" id="tab-btn-v06">v0.6 plan <span class="badge">3 sprints</span></button>
    <button class="tab" data-tab="v1plus" role="tab" aria-selected="false" aria-controls="tab-v1plus" id="tab-btn-v1plus">V1 → V3 <span class="badge">à venir</span></button>
    <button class="tab" data-tab="convergence" role="tab" aria-selected="false" aria-controls="tab-convergence" id="tab-btn-convergence">Trajectoire détaillée</button>
    <button class="tab" data-tab="fusion-v05" role="tab" aria-selected="false" aria-controls="tab-fusion-v05" id="tab-btn-fusion-v05">v0.5 livré <span class="badge">5/5 sprints</span></button>
    <button class="tab" data-tab="release-notes" role="tab" aria-selected="false" aria-controls="tab-release-notes" id="tab-btn-release-notes">Release notes</button>
    <button class="tab" data-tab="journal" role="tab" aria-selected="false" aria-controls="tab-journal" id="tab-btn-journal">Journal &amp; écarts <span class="badge" id="journal-badge">live</span></button>
  </nav>

  <!-- ============================================================ -->
  <!-- TAB 0 — Vue d'ensemble (NOUVEAU défaut)                       -->
  <!-- ============================================================ -->
  <div class="tab-pane active" id="tab-overview" role="tabpanel" aria-labelledby="tab-btn-overview">

    <section class="ov-exec-summary" aria-label="Resume executif">
      <p class="ov-exec-line"><strong>v0.5 LIVRÉ</strong> ✅ <span class="ov-exec-sep">·</span> <strong>v0.6 EN COURS</strong> ⚙ S6.1 démarrée 26/04 <span class="ov-exec-sep">·</span> <strong>V1</strong> (T3 2026 → T1 2027) <span class="ov-exec-sep">·</span> <strong>Action</strong> : générer maquette Claude Design (CEO manuel)</p>
    </section>

